---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBanner from '../components/PageBanner.astro';
import { games, winPoints } from '../data/games';
import { guests } from '../data/guests';

const gameOptions = games.map((g) => g.name).sort((a, b) => a.localeCompare(b));
const playerOptions = guests.filter((g) => !g.statusLine).map((g) => g.name);

const gamePointsData = JSON.stringify(
  Object.fromEntries(games.map((g) => [g.name, winPoints(g)]))
);
---

<BaseLayout title="Wins — BaileyCon" active="wins">
  <PageBanner
    eyebrow="THE VICTORY LEDGER"
    title="Wins"
    subtitle="Every triumph, tallied. Record the fallen, crown the victors."
  />

  <!-- ===== TOP-3 PODIUM ===== -->
  <section class="bc-podium-section">
    <h2 class="bc-podium-title">Champions of the Table</h2>
    <div class="bc-podium-grid" id="podium-grid">
      <p class="bc-loading">Fetching the standings&hellip;</p>
    </div>
  </section>

  <section class="bc-wins-section">
    <!-- FORM -->
    <div class="bc-win-form">
      <h2 class="bc-form-title">Record a Win</h2>

      <label class="bc-label" for="win-game">THE GAME</label>
      <div class="bc-game-row">
        <select class="bc-field" id="win-game">
          <option value="">&mdash; choose a game &mdash;</option>
          {gameOptions.map((g) => (
            <option value={g}>{g}</option>
          ))}
          <option value="__other__">Game not listed</option>
        </select>
        <span id="win-preview" class="bc-win-preview"></span>
      </div>

      <div id="win-custom-fields" class="bc-custom-fields" hidden>
        <label class="bc-label" for="win-custom-name">GAME NAME</label>
        <input class="bc-field" type="text" id="win-custom-name" placeholder="What did you play?" style="margin-bottom:16px;" />

        <label class="bc-label" for="win-custom-points">WIN VALUE (PTS)</label>
        <input class="bc-field" type="number" id="win-custom-points" min="1" step="1" placeholder="e.g. 3" style="margin-bottom:16px;" />
      </div>

      <label class="bc-label" for="win-player" style="margin-top:16px;">THE VICTOR</label>
      <select class="bc-field" id="win-player" style="margin-bottom:20px;">
        <option value="">&mdash; choose a player &mdash;</option>
        {playerOptions.map((p) => (
          <option value={p}>{p}</option>
        ))}
      </select>

      <button id="win-submit" class="bc-submit-btn" disabled>RECORD THE WIN</button>
      <p id="win-status" class="bc-status" hidden></p>
    </div>

    <!-- LIST -->
    <div>
      <div class="bc-list-head">
        <h2 class="bc-list-title">Recent Victories</h2>
        <span id="win-count" class="bc-count">&hellip;</span>
      </div>
      <div id="win-list" class="bc-list">
        <p class="bc-loading">Fetching the ledger&hellip;</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script type="application/json" id="wins-game-points-data" set:html={gamePointsData}></script>

<template id="win-card-template">
  <div class="bc-win-card">
    <span class="bc-win-game"></span>
    <span class="bc-win-player"></span>
    <span class="bc-win-points"></span>
    <span class="bc-win-date"></span>
  </div>
</template>

<template id="podium-card-template">
  <div class="bc-podium-card">
    <div class="bc-podium-rank"></div>
    <div class="bc-podium-name"></div>
    <div class="bc-podium-points"></div>
    <div class="bc-podium-wins"></div>
  </div>
</template>

<style>
  .bc-podium-section {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 28px 48px;
    text-align: center;
  }
  .bc-podium-title {
    margin: 0 0 26px;
    font-family: 'Lato', sans-serif;
    font-weight: 900;
    font-size: 34px;
    color: #c79a1f;
  }
  .bc-podium-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    align-items: end;
  }
  .bc-podium-card {
    border: 2px solid #6a4fb0;
    border-radius: 12px;
    background: var(--bc-card-purple);
    box-shadow: 5px 5px 0 var(--bc-blue);
    padding: 22px 16px 20px;
  }
  .bc-podium-card[data-rank='1'] {
    border-color: var(--bc-gold);
    transform: translateY(-14px);
  }
  .bc-podium-rank {
    font-family: 'Raleway', sans-serif;
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 3px;
    color: var(--bc-card-label);
    margin-bottom: 8px;
  }
  .bc-podium-card[data-rank='1'] .bc-podium-rank {
    color: var(--bc-gold);
  }
  .bc-podium-name {
    font-family: 'Lato', sans-serif;
    font-weight: 900;
    font-size: 22px;
    color: var(--bc-card-title);
    margin-bottom: 6px;
  }
  .bc-podium-points {
    font-family: 'Raleway', sans-serif;
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 1px;
    color: var(--bc-gold);
  }
  .bc-podium-wins {
    font-family: 'Raleway', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--bc-card-label);
    margin-top: 4px;
  }

  .bc-wins-section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 28px 40px;
    display: grid;
    grid-template-columns: 400px 1fr;
    gap: 38px;
    align-items: start;
  }
  .bc-win-form {
    position: sticky;
    top: 96px;
    border: 2px solid var(--bc-gold);
    border-radius: 14px;
    background: var(--bc-card-blueviolet);
    padding: 30px 28px;
    box-shadow: 6px 6px 0 var(--bc-deep-twilight);
  }
  .bc-form-title {
    margin: 0 0 24px;
    font-family: 'Lato', sans-serif;
    font-weight: 900;
    font-size: 28px;
    color: var(--bc-gold);
  }
  .bc-label {
    display: block;
    font-family: 'Raleway', sans-serif;
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 1.5px;
    color: var(--bc-card-form-label);
    margin-bottom: 8px;
    text-transform: uppercase;
  }
  .bc-game-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }
  .bc-win-preview {
    font-family: 'Lato', sans-serif;
    font-weight: 700;
    font-size: 13px;
    color: var(--bc-gold);
    white-space: nowrap;
  }
  .bc-custom-fields {
    border-top: 1px solid rgba(255, 255, 255, 0.14);
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    padding: 16px 0 0;
    margin-bottom: 4px;
  }
  .bc-submit-btn {
    width: 100%;
    border: 2px solid transparent;
    border-radius: 9px;
    padding: 15px;
    font-family: 'Lato', sans-serif;
    font-weight: 900;
    font-size: 15px;
    letter-spacing: 1px;
    cursor: not-allowed;
    color: rgba(20, 19, 43, 0.45);
    background: rgba(255, 207, 92, 0.45);
  }
  .bc-submit-btn:not(:disabled) {
    cursor: pointer;
    color: #14132b;
    background: var(--bc-gold);
    border-color: #14132b;
    box-shadow: 4px 4px 0 #14132b;
  }
  .bc-status {
    margin: 12px 0 0;
    font-family: 'Raleway', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1px;
    color: #e2d6ff;
    text-align: center;
  }
  .bc-status.is-error {
    color: #ffc2c2;
  }

  .bc-list-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 2px solid #e2e8f7;
    padding-bottom: 14px;
    margin-bottom: 24px;
  }
  .bc-list-title {
    margin: 0;
    font-family: 'Lato', sans-serif;
    font-weight: 900;
    font-size: 30px;
    color: var(--bc-ink-strong);
  }
  .bc-count {
    font-family: 'Raleway', sans-serif;
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 2px;
    color: var(--bc-faint);
  }
  .bc-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .bc-loading {
    font-family: 'Lato', sans-serif;
    color: var(--bc-muted);
  }
  .bc-win-card {
    border: 2px solid #6a4fb0;
    border-radius: 12px;
    background: var(--bc-card-purple);
    box-shadow: 6px 6px 0 var(--bc-blue);
    padding: 18px 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    font-family: 'Lato', sans-serif;
    font-size: 15px;
  }
  .bc-win-game {
    color: #14132b;
    background: var(--bc-gold);
    border-radius: 20px;
    padding: 6px 16px;
    font-weight: 700;
    font-size: 14px;
  }
  .bc-win-player {
    color: var(--bc-card-title);
    font-weight: 900;
    font-size: 20px;
    flex: 1;
  }
  .bc-win-points {
    color: var(--bc-gold);
    font-weight: 700;
  }
  .bc-win-date {
    color: var(--bc-card-label);
    font-size: 13px;
  }

  @media (max-width: 860px) {
    .bc-wins-section {
      grid-template-columns: 1fr;
    }
    .bc-win-form {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .bc-podium-grid {
      grid-template-columns: 1fr;
    }
    .bc-podium-card[data-rank='1'] {
      transform: none;
      order: -1;
    }
  }
</style>

<script>
  import { supabase, supabaseConfigured } from '../lib/supabase';
  import { pointsForWin, type WinRow as WinRowBase } from '../lib/wins';

  interface WinRow extends WinRowBase {
    id: number;
    created_at: string;
  }

  const CUSTOM_VALUE = '__other__';

  const pointsDataEl = document.getElementById('wins-game-points-data');
  const gamePoints: Record<string, number> = pointsDataEl
    ? JSON.parse(pointsDataEl.textContent || '{}')
    : {};

  const gameSelect = document.getElementById('win-game') as HTMLSelectElement;
  const playerSelect = document.getElementById('win-player') as HTMLSelectElement;
  const previewEl = document.getElementById('win-preview') as HTMLSpanElement;
  const customFields = document.getElementById('win-custom-fields') as HTMLDivElement;
  const customNameInput = document.getElementById('win-custom-name') as HTMLInputElement;
  const customPointsInput = document.getElementById('win-custom-points') as HTMLInputElement;
  const submitBtn = document.getElementById('win-submit') as HTMLButtonElement;
  const statusEl = document.getElementById('win-status') as HTMLParagraphElement;
  const listEl = document.getElementById('win-list') as HTMLDivElement;
  const countEl = document.getElementById('win-count') as HTMLSpanElement;
  const template = document.getElementById('win-card-template') as HTMLTemplateElement;
  const podiumGrid = document.getElementById('podium-grid') as HTMLDivElement;
  const podiumTemplate = document.getElementById('podium-card-template') as HTMLTemplateElement;

  function formatDate(iso: string) {
    const d = new Date(iso);
    return d.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' });
  }

  function isCustomSelected() {
    return gameSelect.value === CUSTOM_VALUE;
  }

  function updatePreview() {
    if (isCustomSelected()) {
      const n = Number(customPointsInput.value);
      previewEl.textContent = customPointsInput.value && n >= 1 ? `= ${n} PTS` : '';
      return;
    }
    const pts = gamePoints[gameSelect.value];
    previewEl.textContent = gameSelect.value && pts !== undefined ? `= ${pts} PTS` : '';
  }

  function updateSubmitState() {
    if (isCustomSelected()) {
      const nameOk = customNameInput.value.trim().length > 0;
      const pointsOk = Number(customPointsInput.value) >= 1;
      submitBtn.disabled = !(nameOk && pointsOk && playerSelect.value);
      return;
    }
    submitBtn.disabled = !(gameSelect.value && playerSelect.value);
  }

  gameSelect.addEventListener('change', () => {
    customFields.hidden = !isCustomSelected();
    if (!isCustomSelected()) {
      customNameInput.value = '';
      customPointsInput.value = '';
    }
    updatePreview();
    updateSubmitState();
  });
  playerSelect.addEventListener('change', updateSubmitState);
  customNameInput.addEventListener('input', updateSubmitState);
  customPointsInput.addEventListener('input', () => {
    updatePreview();
    updateSubmitState();
  });

  function renderLedger(rows: WinRow[]) {
    listEl.innerHTML = '';
    countEl.textContent = `${rows.length} ${rows.length === 1 ? 'WIN' : 'WINS'}`;
    if (!rows.length) {
      const p = document.createElement('p');
      p.className = 'bc-loading';
      p.textContent = 'No wins recorded yet — be the first to claim victory.';
      listEl.appendChild(p);
      return;
    }
    for (const r of rows) {
      const node = template.content.cloneNode(true) as DocumentFragment;
      (node.querySelector('.bc-win-game') as HTMLElement).textContent = r.game;
      (node.querySelector('.bc-win-player') as HTMLElement).textContent = r.player;
      const pts = pointsForWin(r, gamePoints);
      (node.querySelector('.bc-win-points') as HTMLElement).textContent = `${pts} PTS`;
      (node.querySelector('.bc-win-date') as HTMLElement).textContent = formatDate(r.created_at);
      listEl.appendChild(node);
    }
  }

  interface PlayerTally {
    points: number;
    wins: number;
  }

  function renderPodium(rows: WinRow[]) {
    const totals = new Map<string, PlayerTally>();
    for (const r of rows) {
      const entry = totals.get(r.player) || { points: 0, wins: 0 };
      entry.points += pointsForWin(r, gamePoints);
      entry.wins += 1;
      totals.set(r.player, entry);
    }
    // Rank by total points; ties go to whoever notched more wins to get there
    // (quantity over quality). A remaining tie is settled by a d20 roll at
    // the table, not something the site can decide — see the Rules page.
    const ranked = Array.from(totals.entries())
      .sort((a, b) => b[1].points - a[1].points || b[1].wins - a[1].wins || a[0].localeCompare(b[0]))
      .slice(0, 3);

    podiumGrid.innerHTML = '';
    if (!ranked.length) {
      const p = document.createElement('p');
      p.className = 'bc-loading';
      p.textContent = 'No victors crowned yet — record the first win below.';
      podiumGrid.appendChild(p);
      return;
    }
    // Visual podium order: 2nd, 1st, 3rd (classic center-elevated layout).
    const order = [1, 0, 2].filter((i) => i < ranked.length);
    for (const i of order) {
      const [name, stats] = ranked[i];
      const node = podiumTemplate.content.cloneNode(true) as DocumentFragment;
      const card = node.querySelector('.bc-podium-card') as HTMLElement;
      card.dataset.rank = String(i + 1);
      (node.querySelector('.bc-podium-rank') as HTMLElement).textContent =
        i === 0 ? '1ST' : i === 1 ? '2ND' : '3RD';
      (node.querySelector('.bc-podium-name') as HTMLElement).textContent = name;
      (node.querySelector('.bc-podium-points') as HTMLElement).textContent = `${stats.points} PTS`;
      (node.querySelector('.bc-podium-wins') as HTMLElement).textContent = `${stats.wins} ${stats.wins === 1 ? 'WIN' : 'WINS'}`;
      podiumGrid.appendChild(node);
    }
  }

  async function loadWins() {
    if (!supabaseConfigured) {
      listEl.innerHTML = '<p class="bc-loading">Wins backend is not configured yet — ask the host to finish Supabase setup.</p>';
      countEl.textContent = '0 WINS';
      podiumGrid.innerHTML = '<p class="bc-loading">Leaderboard needs the Supabase backend configured.</p>';
      return;
    }
    const { data, error } = await supabase
      .from('wins')
      .select('*')
      .order('created_at', { ascending: false });
    if (error) {
      listEl.innerHTML = `<p class="bc-loading">Could not load wins (${error.message}).</p>`;
      podiumGrid.innerHTML = '<p class="bc-loading">Standings unavailable right now.</p>';
      return;
    }
    const rows = (data as WinRow[]) || [];
    renderLedger(rows);
    renderPodium(rows);
  }

  async function submitWin() {
    const player = playerSelect.value;
    const custom = isCustomSelected();
    const game = custom ? customNameInput.value.trim() : gameSelect.value;
    const customPoints = Number(customPointsInput.value);
    if (!game || !player) return;
    if (custom && !(customPoints >= 1)) return;

    submitBtn.disabled = true;
    statusEl.hidden = true;
    statusEl.classList.remove('is-error');

    // Only custom ("not listed") wins carry an explicit points override —
    // known games keep inserting the same shape as before so recording a
    // normal win never depends on the newer `points` column existing yet.
    const payload: { game: string; player: string; points?: number } = { game, player };
    if (custom) payload.points = customPoints;

    const { error } = await supabase.from('wins').insert(payload);
    if (error) {
      statusEl.textContent = `Could not record win (${error.message}).`;
      statusEl.classList.add('is-error');
      statusEl.hidden = false;
      updateSubmitState();
      return;
    }

    gameSelect.value = '';
    playerSelect.value = '';
    customFields.hidden = true;
    customNameInput.value = '';
    customPointsInput.value = '';
    updatePreview();
    statusEl.textContent = 'Recorded! The ledger has been updated.';
    statusEl.hidden = false;
    updateSubmitState();
    await loadWins();
  }

  submitBtn.addEventListener('click', submitWin);

  updateSubmitState();
  loadWins();
</script>
