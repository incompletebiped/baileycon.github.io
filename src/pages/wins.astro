---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBanner from '../components/PageBanner.astro';
import { games, winPoints } from '../data/games';
import { activeGuests } from '../data/guests';

const gameOptions = games.map((g) => g.name).sort((a, b) => a.localeCompare(b));
const playerOptions = activeGuests.map((g) => g.name);

const gamePointsData = JSON.stringify(
  Object.fromEntries(games.map((g) => [g.name, winPoints(g)]))
);
const playerOptionsData = JSON.stringify(playerOptions);
---

<BaseLayout title="Wins — BaileyCon" active="wins">
  <PageBanner
    eyebrow="BaileyCon III"
    title="Wins"
    subtitle="Every triumph, tallied. Record the fallen, crown the victors."
  />

  <section class="bc-split-2col">
    <!-- FORM -->
    <div class="bc-form-col">
      <h2 class="bc-form-title">Log a Win</h2>

      <label class="bc-label" for="win-game">Game</label>
      <div class="bc-game-row">
        <select class="bc-field" id="win-game">
          <option value="">Choose a game…</option>
          {gameOptions.map((g) => (
            <option value={g}>{g}</option>
          ))}
          <option value="__other__">Game not listed</option>
        </select>
        <span id="win-preview" class="bc-win-preview"></span>
      </div>

      <div id="win-custom-fields" class="bc-custom-fields" hidden>
        <label class="bc-label" for="win-custom-name">Game Name</label>
        <input class="bc-field" type="text" id="win-custom-name" placeholder="What did you play?" style="margin-bottom:16px;" />

        <label class="bc-label" for="win-custom-points">Win Value (PTS)</label>
        <input class="bc-field" type="number" id="win-custom-points" min="1" step="1" placeholder="e.g. 3" style="margin-bottom:16px;" />
      </div>

      <label class="bc-label" for="win-player" style="margin-top:16px;">Winner</label>
      <select class="bc-field" id="win-player" style="margin-bottom:16px;">
        <option value="">Choose a player…</option>
        {playerOptions.map((p) => (
          <option value={p}>{p}</option>
        ))}
      </select>

      <label class="bc-label" for="win-notes">Notes (optional)</label>
      <textarea class="bc-field" id="win-notes" rows="3" placeholder="How did it happen? Epic comeback? Devastating betrayal?" style="margin-bottom:18px;"></textarea>

      <button id="win-submit" class="bc-submit-btn" disabled>Record Win</button>
      <p id="win-status" class="bc-status" hidden></p>

      <div class="bc-recent" id="recent-wrap" hidden>
        <div class="bc-recent-head">Recent</div>
        <div id="recent-list" class="bc-recent-list"></div>
      </div>
    </div>

    <!-- LEADERBOARD -->
    <div class="bc-board-col">
      <div class="bc-list-head">
        <h2 class="bc-list-title">Leaderboard</h2>
      </div>
      <p class="bc-leader-caption" id="leader-caption">&hellip;</p>
      <div id="leaderboard" class="bc-leaderboard">
        <p class="bc-loading">Fetching the standings&hellip;</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script type="application/json" id="wins-game-points-data" set:html={gamePointsData}></script>
<script type="application/json" id="wins-player-options-data" set:html={playerOptionsData}></script>

<template id="recent-item-template">
  <div class="bc-recent-item">
    <span class="bc-recent-player"></span>
    <span class="bc-recent-game"></span>
    <span class="bc-recent-date"></span>
    <p class="bc-recent-notes" hidden></p>
  </div>
</template>

<template id="leaderboard-row-template">
  <div class="bc-lb-row">
    <span class="bc-lb-rank"></span>
    <span class="bc-lb-name"></span>
    <div class="bc-lb-bar-track">
      <div class="bc-lb-bar-fill"></div>
    </div>
    <span class="bc-lb-wins"></span>
  </div>
</template>

<style is:global>
  .bc-split-2col {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 28px 70px;
    display: grid;
    grid-template-columns: 36% 64%;
    gap: 0;
    min-height: calc(100vh - 400px);
  }
  .bc-form-col {
    border-right: 1px solid var(--bc-border-gold);
    padding: 8px 36px 40px 8px;
  }
  .bc-board-col {
    padding: 8px 8px 40px 36px;
  }
  .bc-form-title {
    margin: 0 0 24px;
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 24px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--bc-gold);
  }
  .bc-label {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1.5px;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 8px;
    text-transform: uppercase;
  }
  .bc-game-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }
  .bc-win-preview {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 13px;
    color: var(--bc-gold);
    white-space: nowrap;
  }
  .bc-custom-fields {
    border-top: 1px solid var(--bc-border-gold);
    border-bottom: 1px solid var(--bc-border-gold);
    padding: 16px 0 0;
    margin-bottom: 4px;
  }
  .bc-submit-btn {
    width: 100%;
    border: 1.5px solid var(--bc-gold);
    border-radius: 9px;
    padding: 15px;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: not-allowed;
    color: rgba(255, 207, 92, 0.35);
    background: transparent;
    opacity: 0.4;
    transition: opacity 0.15s;
  }
  .bc-submit-btn:not(:disabled) {
    cursor: pointer;
    color: #1a0e02;
    background: var(--bc-gold);
    opacity: 1;
  }
  .bc-status {
    margin: 12px 0 0;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 12px;
    color: var(--bc-blue);
    text-align: center;
  }
  .bc-status.is-error {
    color: var(--bc-error);
  }
  .bc-recent {
    margin-top: 30px;
    border-top: 1px solid var(--bc-border-gold);
    padding-top: 20px;
  }
  .bc-recent-head {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 12px;
  }
  .bc-recent-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .bc-recent-item {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
  }
  .bc-recent-player {
    color: var(--bc-gold);
    font-weight: 700;
  }
  .bc-recent-game {
    color: rgba(255, 255, 255, 0.5);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 60%;
  }
  .bc-recent-date {
    color: rgba(255, 255, 255, 0.3);
    margin-left: auto;
    font-size: 11px;
  }
  .bc-recent-notes {
    flex-basis: 100%;
    margin: 2px 0 0;
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 12.5px;
    color: rgba(255, 255, 255, 0.4);
  }

  .bc-list-head {
    margin-bottom: 4px;
  }
  .bc-list-title {
    margin: 0;
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 24px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #fff;
  }
  .bc-leader-caption {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 15px;
    color: rgba(255, 255, 255, 0.55);
    margin: 8px 0 26px;
  }
  .bc-loading {
    font-family: 'Space Grotesk', sans-serif;
    color: rgba(255, 255, 255, 0.4);
  }
  .bc-leaderboard {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .bc-lb-row {
    display: grid;
    grid-template-columns: 28px 120px 1fr 60px;
    align-items: center;
    gap: 12px;
  }
  .bc-lb-rank {
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 15px;
    text-align: center;
  }
  .bc-lb-name {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.75);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .bc-lb-bar-track {
    height: 10px;
    border-radius: 5px;
    background: rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }
  .bc-lb-bar-fill {
    height: 100%;
    border-radius: 5px;
    background: linear-gradient(90deg, var(--bc-blue), var(--bc-gold));
    width: var(--bar-w, 0%);
    animation: bc-bar-grow 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  @keyframes bc-bar-grow {
    from {
      width: 0;
    }
    to {
      width: var(--bar-w, 0%);
    }
  }
  .bc-lb-wins {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 12px;
    color: var(--bc-gold);
    text-align: right;
  }

  @media (max-width: 760px) {
    .bc-split-2col {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    .bc-form-col {
      border-right: none;
      border-bottom: 1px solid var(--bc-border-gold);
      padding: 8px 8px 30px;
    }
    .bc-board-col {
      padding: 30px 8px 40px;
    }
    .bc-lb-row {
      grid-template-columns: 24px 90px 1fr 50px;
      gap: 8px;
    }
  }
</style>

<script>
  import { supabase, supabaseConfigured } from '../lib/supabase';
  import { pointsForWin, type WinRow as WinRowBase } from '../lib/wins';

  interface WinRow extends WinRowBase {
    id: number;
    notes?: string | null;
    created_at: string;
  }

  const CUSTOM_VALUE = '__other__';

  const pointsDataEl = document.getElementById('wins-game-points-data');
  const gamePoints: Record<string, number> = pointsDataEl
    ? JSON.parse(pointsDataEl.textContent || '{}')
    : {};
  const playersDataEl = document.getElementById('wins-player-options-data');
  const playerOptions: string[] = playersDataEl ? JSON.parse(playersDataEl.textContent || '[]') : [];

  const gameSelect = document.getElementById('win-game') as HTMLSelectElement;
  const playerSelect = document.getElementById('win-player') as HTMLSelectElement;
  const notesInput = document.getElementById('win-notes') as HTMLTextAreaElement;
  const previewEl = document.getElementById('win-preview') as HTMLSpanElement;
  const customFields = document.getElementById('win-custom-fields') as HTMLDivElement;
  const customNameInput = document.getElementById('win-custom-name') as HTMLInputElement;
  const customPointsInput = document.getElementById('win-custom-points') as HTMLInputElement;
  const submitBtn = document.getElementById('win-submit') as HTMLButtonElement;
  const statusEl = document.getElementById('win-status') as HTMLParagraphElement;
  const recentWrap = document.getElementById('recent-wrap') as HTMLDivElement;
  const recentList = document.getElementById('recent-list') as HTMLDivElement;
  const recentTemplate = document.getElementById('recent-item-template') as HTMLTemplateElement;
  const leaderboardEl = document.getElementById('leaderboard') as HTMLDivElement;
  const leaderCaption = document.getElementById('leader-caption') as HTMLParagraphElement;
  const leaderboardTemplate = document.getElementById('leaderboard-row-template') as HTMLTemplateElement;

  function formatDate(iso: string) {
    const d = new Date(iso);
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  function isCustomSelected() {
    return gameSelect.value === CUSTOM_VALUE;
  }

  function updatePreview() {
    if (isCustomSelected()) {
      const n = Number(customPointsInput.value);
      previewEl.textContent = customPointsInput.value && n >= 1 ? `= ${n} PTS` : '';
      return;
    }
    const pts = gamePoints[gameSelect.value];
    previewEl.textContent = gameSelect.value && pts !== undefined ? `= ${pts} PTS` : '';
  }

  function updateSubmitState() {
    if (isCustomSelected()) {
      const nameOk = customNameInput.value.trim().length > 0;
      const pointsOk = Number(customPointsInput.value) >= 1;
      submitBtn.disabled = !(nameOk && pointsOk && playerSelect.value);
      return;
    }
    submitBtn.disabled = !(gameSelect.value && playerSelect.value);
  }

  gameSelect.addEventListener('change', () => {
    customFields.hidden = !isCustomSelected();
    if (!isCustomSelected()) {
      customNameInput.value = '';
      customPointsInput.value = '';
    }
    updatePreview();
    updateSubmitState();
  });
  playerSelect.addEventListener('change', updateSubmitState);
  customNameInput.addEventListener('input', updateSubmitState);
  customPointsInput.addEventListener('input', () => {
    updatePreview();
    updateSubmitState();
  });

  function renderRecent(rows: WinRow[]) {
    recentList.innerHTML = '';
    const recent = rows.slice(0, 8);
    recentWrap.hidden = recent.length === 0;
    for (const r of recent) {
      const node = recentTemplate.content.cloneNode(true) as DocumentFragment;
      (node.querySelector('.bc-recent-player') as HTMLElement).textContent = r.player;
      (node.querySelector('.bc-recent-game') as HTMLElement).textContent = r.game;
      (node.querySelector('.bc-recent-date') as HTMLElement).textContent = formatDate(r.created_at);
      const notesEl = node.querySelector('.bc-recent-notes') as HTMLElement;
      if (r.notes) {
        notesEl.textContent = r.notes;
        notesEl.hidden = false;
      }
      recentList.appendChild(node);
    }
  }

  function renderLeaderboard(rows: WinRow[]) {
    const winCounts = new Map<string, number>();
    for (const r of rows) {
      winCounts.set(r.player, (winCounts.get(r.player) || 0) + 1);
    }
    const sorted = playerOptions
      .map((name) => ({ name, wins: winCounts.get(name) || 0 }))
      .sort((a, b) => b.wins - a.wins || a.name.localeCompare(b.name));

    const topWins = sorted[0]?.wins || 0;
    const rankColors = ['#ffcf5c', '#c8c8c8', '#cd7f32'];
    const medals = ['🥇', '🥈', '🥉'];

    leaderboardEl.innerHTML = '';
    sorted.forEach((p, i) => {
      const node = leaderboardTemplate.content.cloneNode(true) as DocumentFragment;
      const rankEl = node.querySelector('.bc-lb-rank') as HTMLElement;
      const hasMedal = i < 3 && p.wins > 0;
      rankEl.textContent = hasMedal ? medals[i] : String(i + 1);
      rankEl.style.color = i < 3 && p.wins > 0 ? rankColors[i] : 'rgba(255,255,255,0.35)';
      const nameEl = node.querySelector('.bc-lb-name') as HTMLElement;
      nameEl.textContent = p.name;
      if (i === 0 && p.wins > 0) nameEl.style.color = '#fff';
      const fill = node.querySelector('.bc-lb-bar-fill') as HTMLElement;
      const barWidth = topWins > 0 ? `${Math.round((p.wins / topWins) * 100)}%` : '0%';
      fill.style.setProperty('--bar-w', barWidth);
      (node.querySelector('.bc-lb-wins') as HTMLElement).textContent = `${p.wins} ${p.wins === 1 ? 'WIN' : 'WINS'}`;
      leaderboardEl.appendChild(node);
    });

    const leader = sorted[0];
    leaderCaption.textContent =
      leader && leader.wins > 0
        ? leader.wins === 1
          ? `${leader.name} is in the lead with 1 win. The quest continues.`
          : `${leader.name} leads with ${leader.wins} wins. The others are getting desperate.`
        : 'No wins recorded yet. The battlefield awaits.';
  }

  async function loadWins() {
    if (!supabaseConfigured) {
      recentWrap.hidden = true;
      leaderboardEl.innerHTML = '<p class="bc-loading">Leaderboard needs the Supabase backend configured.</p>';
      leaderCaption.textContent = '';
      return;
    }
    const { data, error } = await supabase
      .from('wins')
      .select('*')
      .order('created_at', { ascending: false });
    if (error) {
      leaderboardEl.innerHTML = `<p class="bc-loading">Could not load standings (${error.message}).</p>`;
      return;
    }
    const rows = (data as WinRow[]) || [];
    renderRecent(rows);
    renderLeaderboard(rows);
  }

  async function submitWin() {
    const player = playerSelect.value;
    const custom = isCustomSelected();
    const game = custom ? customNameInput.value.trim() : gameSelect.value;
    const customPoints = Number(customPointsInput.value);
    const notes = notesInput.value.trim();
    if (!game || !player) return;
    if (custom && !(customPoints >= 1)) return;

    submitBtn.disabled = true;
    statusEl.hidden = true;
    statusEl.classList.remove('is-error');

    const payload: { game: string; player: string; points?: number; notes?: string } = { game, player };
    if (custom) payload.points = customPoints;
    if (notes) payload.notes = notes;

    const { error } = await supabase.from('wins').insert(payload);
    if (error) {
      statusEl.textContent = `Could not record win (${error.message}).`;
      statusEl.classList.add('is-error');
      statusEl.hidden = false;
      updateSubmitState();
      return;
    }

    gameSelect.value = '';
    playerSelect.value = '';
    notesInput.value = '';
    customFields.hidden = true;
    customNameInput.value = '';
    customPointsInput.value = '';
    updatePreview();
    statusEl.textContent = '✓ Win recorded!';
    statusEl.hidden = false;
    setTimeout(() => {
      statusEl.hidden = true;
    }, 3000);
    updateSubmitState();
    await loadWins();
  }

  submitBtn.addEventListener('click', submitWin);

  updateSubmitState();
  loadWins();
</script>
