---
import BaseLayout from '../layouts/BaseLayout.astro';
import GameCard from '../components/GameCard.astro';
import { games } from '../data/games';
import { withBase } from '../lib/url';
---

<BaseLayout title="BaileyCon — Third Annual" active="home">
  <!-- ===== HERO ===== -->
  <section class="bc-hero">
    <div class="bc-hero-bg" style={`background-image:url(${withBase('/images/hero-comic.jpg')});`}></div>
    <div class="bc-hero-scrim"></div>

    <span class="bc-hero-corner bc-hero-corner-tl"></span>
    <span class="bc-hero-corner bc-hero-corner-tr"></span>
    <span class="bc-hero-corner bc-hero-corner-bl"></span>
    <span class="bc-hero-corner bc-hero-corner-br"></span>

    <div class="bc-hero-side bc-hero-side-l">III &middot; ANNUAL &middot; 2025</div>
    <div class="bc-hero-side bc-hero-side-r">KNIGHT WATCH GAMES</div>

    <div class="bc-hero-inner">
      <h1 class="bc-hero-title">
        <span class="bc-slam-l">BAILEY</span>
        <span class="bc-slam-r">CON</span>
      </h1>
      <div class="bc-hero-strip">
        <span class="bc-hero-line"></span>
        <span class="bc-hero-sublabel">Third Annual &middot; San Antonio, TX</span>
        <span class="bc-hero-line"></span>
      </div>
    </div>

    <div class="bc-scroll-hint">
      <span>Scroll</span>
      <span class="bc-scroll-tick"></span>
    </div>
  </section>

  <!-- ===== EVENT STATS BAND ===== -->
  <section class="bc-stats-band">
    <div class="bc-stats-grid">
      <div><div class="bc-stat-label bc-stat-label--blue">WHEN</div><div class="bc-stat-value">Sat, July 25</div></div>
      <div><div class="bc-stat-label bc-stat-label--blue">HOURS</div><div class="bc-stat-value">Noon &ndash; Midnight</div></div>
      <div><div class="bc-stat-label bc-stat-label--gold">WHERE</div><div class="bc-stat-value">Knight Watch Games</div></div>
      <div><div class="bc-stat-label bc-stat-label--gold">DRESS</div><div class="bc-stat-value">Cloak optional</div></div>
    </div>
  </section>

  <!-- ===== STORY ===== -->
  <section class="bc-tale p5-el p5-snap-u">
    <p class="bc-tale-lead">One knight turning <span class="bc-tale-highlight">Forty.</span></p>
    <p class="bc-tale-text">
      Two years running we&rsquo;ve stormed the tavern with meeples and mischief. For the third annual &mdash; and Bailey&rsquo;s
      fortieth trip &rsquo;round the sun &mdash; we return to Knight Watch Games for a full twelve hours of board games, card
      games, and glorious tabletop shenanigans. Bring your A-game and your worst poker face.
    </p>
  </section>

  <!-- ===== THE TWO HALLS ===== -->
  <section class="bc-section p5-el p5-snap-u">
    <div class="bc-section-head">
      <div class="bc-divider">
        <span class="bc-divider-line"></span>
        <span>&#10231;</span>
        <h2 class="bc-h2">Choose Thy Battlefield</h2>
        <span>&#10230;</span>
        <span class="bc-divider-line"></span>
      </div>
    </div>
    <div class="bc-halls-grid">
      <div class="bc-hall-card bc-hall-card--blue">
        <h3 class="bc-hall-title bc-hall-title--blue">The Renaissance Room</h3>
        <p class="bc-hall-text">Big-box strategy, sprawling campaigns, and games that eat an afternoon whole. Settle in.</p>
      </div>
      <div class="bc-hall-card bc-hall-card--gold">
        <h3 class="bc-hall-title bc-hall-title--gold">The Dark Ages Room</h3>
        <p class="bc-hall-text">Party games, bluffing, betrayal, and loud accusations. No friendships guaranteed to survive.</p>
      </div>
    </div>
  </section>

  <!-- ===== FEATURED GAMES ===== -->
  <section class="bc-section p5-el p5-snap-u">
    <div class="bc-section-head">
      <div class="bc-divider">
        <span class="bc-divider-line"></span>
        <span>&#10231;</span>
        <h2 class="bc-h2">Featured Quests</h2>
        <span>&#10230;</span>
        <span class="bc-divider-line"></span>
      </div>
    </div>
    <div class="bc-featured-grid">
      {games.map((g, i) => (
        <a
          href={withBase(`/games/#${g.slug}`)}
          class:list={['bc-featured-link', i % 2 === 0 ? 'bc-featured-link--gold' : 'bc-featured-link--blue']}
          data-featured-item
          style="display:none;"
        >
          <GameCard game={g} compact />
        </a>
      ))}
    </div>
    <div class="bc-see-all-row">
      <a href={withBase('/games/')} class="bc-see-all">See All Games &rarr;</a>
    </div>
  </section>

  <!-- ===== THE PARTY ===== -->
  <section class="bc-section bc-party p5-el p5-snap-u">
    <div class="bc-divider bc-divider--center">
      <span class="bc-divider-line"></span>
      <span>&#9671;</span>
      <span class="bc-divider-dot">&#9678;</span>
      <span>&#9671;</span>
      <span class="bc-divider-line"></span>
    </div>
    <div class="bc-eyebrow">THE PARTY</div>
    <h2 class="bc-h2">The Party Assembled.</h2>
    <p class="bc-party-text">Twelve players of honour. Collect them all.</p>
    <a href={withBase('/players/')} class="bc-btn bc-btn--solid">View the Roster &rarr;</a>
  </section>

  <!-- ===== CTA BAND ===== -->
  <section class="bc-cta-section p5-el p5-snap-u">
    <div class="bc-cta-band">
      <div>
        <h2 class="bc-cta-title">Played something grand?</h2>
        <p class="bc-cta-text">Leave a review, or scrawl a secret upon the anonymous wall.</p>
      </div>
      <div class="bc-cta-buttons">
        <a href={withBase('/reviews/')} class="bc-btn bc-btn--solid">Leave a Review</a>
        <a href={withBase('/wall/')} class="bc-btn bc-btn--outline">The Wall</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .bc-hero {
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - 52px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #06040f;
  }
  .bc-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.5;
  }
  .bc-hero-scrim {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 40%, rgba(6, 4, 15, 0.25) 0%, rgba(6, 4, 15, 0.82) 78%);
  }
  .bc-hero-corner {
    position: absolute;
    width: 34px;
    height: 34px;
    z-index: 2;
  }
  .bc-hero-corner::before,
  .bc-hero-corner::after {
    content: '';
    position: absolute;
    background: rgba(255, 207, 92, 0.55);
  }
  .bc-hero-corner::before {
    width: 100%;
    height: 1px;
  }
  .bc-hero-corner::after {
    width: 1px;
    height: 100%;
  }
  .bc-hero-corner-tl {
    top: 26px;
    left: 26px;
  }
  .bc-hero-corner-tl::before,
  .bc-hero-corner-tl::after {
    top: 0;
    left: 0;
  }
  .bc-hero-corner-tr {
    top: 26px;
    right: 26px;
  }
  .bc-hero-corner-tr::before,
  .bc-hero-corner-tr::after {
    top: 0;
    right: 0;
  }
  .bc-hero-corner-bl {
    bottom: 26px;
    left: 26px;
  }
  .bc-hero-corner-bl::before,
  .bc-hero-corner-bl::after {
    bottom: 0;
    left: 0;
  }
  .bc-hero-corner-br {
    bottom: 26px;
    right: 26px;
  }
  .bc-hero-corner-br::before,
  .bc-hero-corner-br::after {
    bottom: 0;
    right: 0;
  }
  .bc-hero-side {
    position: absolute;
    top: 50%;
    writing-mode: vertical-rl;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 4px;
    color: rgba(255, 255, 255, 0.3);
    z-index: 2;
    transform: translateY(-50%);
  }
  .bc-hero-side-l {
    left: 40px;
    color: rgba(255, 207, 92, 0.4);
  }
  .bc-hero-side-r {
    right: 40px;
    color: rgba(77, 163, 255, 0.4);
  }
  .bc-hero-inner {
    position: relative;
    z-index: 2;
    text-align: center;
  }
  .bc-hero-title {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 140px;
    line-height: 0.85;
    letter-spacing: 10px;
  }
  .bc-slam-l {
    color: var(--bc-blue);
    text-shadow: 8px 8px 0 #0a0716, 0 0 34px rgba(77, 163, 255, 0.5);
    animation: bc-slam-l 0.65s cubic-bezier(0.25, 0, 0.3, 1) 0.15s both;
  }
  .bc-slam-r {
    color: var(--bc-gold);
    text-shadow: 8px 8px 0 #0a0716, 0 0 34px rgba(255, 207, 92, 0.55);
    animation: bc-slam-r 0.65s cubic-bezier(0.25, 0, 0.3, 1) 0.35s both;
  }
  @keyframes bc-slam-l {
    0% {
      opacity: 0;
      transform: translateX(-260px) skewX(-14deg) scale(0.88);
    }
    58% {
      opacity: 1;
      transform: translateX(24px) skewX(3deg) scale(1.04);
    }
    76% {
      transform: translateX(-10px) skewX(-1.5deg);
    }
    90% {
      transform: translateX(5px);
    }
    100% {
      opacity: 1;
      transform: none;
    }
  }
  @keyframes bc-slam-r {
    0% {
      opacity: 0;
      transform: translateX(260px) skewX(14deg) scale(0.88);
    }
    58% {
      opacity: 1;
      transform: translateX(-24px) skewX(-3deg) scale(1.04);
    }
    76% {
      transform: translateX(10px) skewX(1.5deg);
    }
    90% {
      transform: translateX(-5px);
    }
    100% {
      opacity: 1;
      transform: none;
    }
  }
  .bc-hero-strip {
    margin-top: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }
  .bc-hero-line {
    width: 46px;
    height: 1px;
    background: rgba(255, 255, 255, 0.25);
  }
  .bc-hero-sublabel {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }
  .bc-scroll-hint {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    z-index: 2;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
  }
  .bc-scroll-tick {
    width: 1px;
    height: 26px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.4), transparent);
  }

  .bc-stats-band {
    border-top: 1px solid var(--bc-border-gold);
    border-bottom: 1px solid var(--bc-border-gold);
    padding: 34px 28px;
  }
  .bc-stats-grid {
    max-width: 640px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px 40px;
    text-align: center;
  }
  .bc-stat-label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 3px;
  }
  .bc-stat-label--blue {
    color: var(--bc-blue);
  }
  .bc-stat-label--gold {
    color: var(--bc-gold);
  }
  .bc-stat-value {
    margin-top: 6px;
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 20px;
    color: #fff;
  }

  .bc-tale {
    max-width: 780px;
    margin: 0 auto;
    padding: 70px 28px 60px;
    text-align: center;
  }
  .bc-tale-lead {
    margin: 0 0 22px;
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-style: italic;
    font-size: 28px;
    color: #fff;
  }
  .bc-tale-highlight {
    color: var(--bc-gold);
  }
  .bc-tale-text {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 17px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  .bc-section {
    max-width: var(--bc-max-width);
    margin: 0 auto;
    padding: 0 28px 70px;
  }
  .bc-section-head {
    text-align: center;
    margin-bottom: 34px;
  }
  .bc-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    color: var(--bc-gold);
  }
  .bc-divider-line {
    width: 60px;
    height: 1px;
    background: rgba(255, 207, 92, 0.3);
  }
  .bc-divider-dot {
    color: var(--bc-blue);
  }
  .bc-h2 {
    margin: 0;
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--bc-gold);
  }
  .bc-eyebrow {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 4px;
    color: var(--bc-eyebrow);
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .bc-see-all-row {
    text-align: center;
    margin-top: 30px;
  }
  .bc-see-all {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255, 207, 92, 0.6);
  }
  .bc-see-all:hover {
    color: var(--bc-gold);
  }

  .bc-halls-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .bc-hall-card {
    border-radius: 12px;
    padding: 28px 26px;
    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.2s;
  }
  .bc-hall-card--blue {
    background: rgba(77, 163, 255, 0.07);
    border: 1px solid rgba(77, 163, 255, 0.3);
  }
  .bc-hall-card--blue:hover {
    box-shadow: 7px 7px 0 rgba(77, 163, 255, 0.25);
  }
  .bc-hall-card--gold {
    background: rgba(255, 207, 92, 0.05);
    border: 1px solid rgba(255, 207, 92, 0.28);
  }
  .bc-hall-card--gold:hover {
    box-shadow: 7px 7px 0 rgba(255, 207, 92, 0.25);
  }
  .bc-hall-title {
    margin: 0 0 12px;
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-size: 24px;
  }
  .bc-hall-title--blue {
    color: var(--bc-blue);
  }
  .bc-hall-title--gold {
    color: var(--bc-gold);
  }
  .bc-hall-text {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
    color: rgba(255, 255, 255, 0.6);
  }

  .bc-featured-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .bc-featured-link {
    display: block;
    text-decoration: none;
    color: inherit;
    border-top: 3px solid transparent;
    border-radius: 10px 10px 0 0;
    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .bc-featured-link--gold {
    border-top-color: var(--bc-gold);
  }
  .bc-featured-link--blue {
    border-top-color: var(--bc-blue);
  }
  .bc-featured-link:hover {
    transform: translateY(-6px);
  }

  .bc-party {
    text-align: center;
    padding-bottom: 24px;
  }
  .bc-divider--center {
    margin-bottom: 20px;
  }
  .bc-party .bc-h2 {
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-size: 34px;
    letter-spacing: 0.5px;
    text-transform: none;
    color: #fff;
    margin: 6px 0 10px;
  }
  .bc-party-text {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 0 26px;
  }

  .bc-btn {
    display: inline-block;
    padding: 15px 28px;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    border-radius: 8px;
    border: 1.5px solid transparent;
    transition: transform 0.15s ease, background 0.15s ease;
  }
  .bc-btn--solid {
    background: var(--bc-gold);
    color: #1a0e02;
  }
  .bc-btn--solid:hover {
    transform: skewX(-4deg) scale(1.05);
  }
  .bc-btn--outline {
    background: transparent;
    border-color: var(--bc-gold);
    color: var(--bc-gold);
  }
  .bc-btn--outline:hover {
    background: rgba(255, 207, 92, 0.12);
    transform: skewX(-4deg) scale(1.05);
  }

  .bc-cta-section {
    max-width: var(--bc-max-width);
    margin: 0 auto;
    padding: 0 28px 20px;
  }
  .bc-cta-band {
    border: 1px solid var(--bc-border-gold);
    border-radius: 14px;
    background: var(--bc-panel);
    padding: 40px 36px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
  }
  .bc-cta-title {
    margin: 0 0 6px;
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 26px;
    color: #fff;
  }
  .bc-cta-text {
    margin: 0;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    color: rgba(255, 255, 255, 0.55);
  }
  .bc-cta-buttons {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  /* ===== scroll-reveal ===== */
  /* Content stays fully visible unless JS confirms it can reveal it on scroll
     (html.js-reveal), so a script error or no-JS never leaves it stuck at opacity:0. */
  :global(html.js-reveal) .p5-el {
    opacity: 0;
  }
  :global(html.js-reveal) .p5-el.vis.p5-snap-u {
    animation: p5-snap-u 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  @keyframes p5-snap-u {
    from {
      opacity: 0;
      transform: translateY(28px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 900px) {
    .bc-hero-title {
      font-size: 90px;
    }
    .bc-halls-grid {
      grid-template-columns: 1fr;
    }
    .bc-featured-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 760px) {
    .bc-hero-side {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .bc-hero-title {
      font-size: 58px !important;
      letter-spacing: 4px !important;
    }
    .bc-stats-grid {
      gap: 16px 20px;
    }
    .bc-tale-text {
      font-size: 16px;
    }
    .bc-featured-grid {
      grid-template-columns: 1fr;
    }
    .bc-cta-band {
      padding: 28px 22px;
    }
    .bc-cta-title {
      font-size: 22px;
    }
  }
</style>

<script>
  const items = Array.from(document.querySelectorAll<HTMLElement>('[data-featured-item]'));
  const FEATURED_COUNT = 4;
  const indices = items.map((_, i) => i);

  // Partial Fisher-Yates: only shuffle enough to isolate FEATURED_COUNT random picks.
  for (let i = indices.length - 1; i > 0 && i > indices.length - 1 - FEATURED_COUNT; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [indices[i], indices[j]] = [indices[j], indices[i]];
  }
  const chosen = new Set(indices.slice(-FEATURED_COUNT));

  items.forEach((el, i) => {
    if (chosen.has(i)) el.style.display = '';
  });

  // Scroll-reveal: fires each .p5-el once it enters the viewport. Only switch
  // on the CSS that hides them (html.js-reveal) once the observer is actually
  // wired up, so a script error or disabled JS never leaves content invisible.
  function initScrollReveal() {
    if (typeof IntersectionObserver === 'undefined') return;
    document.documentElement.classList.add('js-reveal');
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('vis');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.05 }
    );
    document.querySelectorAll('.p5-el:not(.vis)').forEach((el) => io.observe(el));
  }
  setTimeout(initScrollReveal, 150);
  setTimeout(initScrollReveal, 800);
</script>
