---
import BaseLayout from '../layouts/BaseLayout.astro';
import GameCard from '../components/GameCard.astro';
import { games } from '../data/games';
import { guests } from '../data/guests';
import { withBase } from '../lib/url';

const company = guests.map((g) => ({ initial: g.name[0], slug: g.slug }));
---

<BaseLayout title="BaileyCon — Third Annual" active="home">
  <!-- ===== HERO ===== -->
  <section class="bc-hero">
    <div class="bc-hero-40">40</div>

    <div class="bc-hero-inner">
      <div class="bc-hero-eyebrow">THIRD ANNUAL &middot; <span class="bc-nowrap">SAN ANTONIO, TX</span></div>
      <h1 class="bc-hero-title">
        <span class="bc-hero-bailey">BAILEY</span><span class="bc-hero-con">CON</span>
      </h1>
      <p class="bc-hero-subtitle">
        Twelve hours. Two taverns&rsquo; worth of halls. Ten players of honour. One knight turning <span class="bc-hero-forty">FORTY</span>.
      </p>

      <div class="bc-badge-card">
        <div class="bc-badge-punch"></div>
        <div class="bc-badge-grid">
          <div><div class="bc-badge-label">WHEN</div><div class="bc-badge-value">Sat, July 25</div></div>
          <div><div class="bc-badge-label">HOURS</div><div class="bc-badge-value">Noon &ndash; Midnight</div></div>
          <div><div class="bc-badge-label">WHERE</div><div class="bc-badge-value">Knight Watch Games</div></div>
          <div><div class="bc-badge-label">DRESS</div><div class="bc-badge-value">Cloak optional</div></div>
        </div>
      </div>

      <div class="bc-hero-ctas">
        <a href={withBase('/players/')} class="bc-btn bc-btn--solid">MEET THE PARTY</a>
        <a href={withBase('/games/')} class="bc-btn bc-btn--outline-hero">BROWSE THE GAMES</a>
      </div>
    </div>
  </section>

  <!-- ===== THE TALE ===== -->
  <section class="bc-tale">
    <div class="bc-fleuron">&#10087;</div>
    <div class="bc-eyebrow">THE TALE THUS FAR</div>
    <p class="bc-tale-text">
      Two years running we&rsquo;ve stormed the tavern with meeples and mischief. For the third annual &mdash; and Bailey&rsquo;s
      <span class="bc-tale-highlight">fortieth</span> trip &rsquo;round the sun &mdash; we return to Knight Watch Games for a
      full twelve hours of board games, card games, and glorious tabletop shenanigans. Bring your A-game and your worst poker face.
    </p>
  </section>

  <!-- ===== THE TWO HALLS ===== -->
  <section class="bc-section">
    <div class="bc-section-head">
      <div class="bc-eyebrow">TWO RESERVED HALLS</div>
      <h2 class="bc-h2">Choose Thy Battlefield</h2>
    </div>
    <div class="bc-halls-grid">
      <div class="bc-hall-card bc-hall-card--blue">
        <div class="bc-hall-eyebrow bc-hall-eyebrow--blue">HALL THE FIRST</div>
        <h3 class="bc-hall-title bc-hall-title--blue">The Renaissance Room</h3>
        <p class="bc-hall-text bc-hall-text--blue">Where the deep thinkers dwell. Big-box strategy, sprawling campaigns, and games that eat an afternoon whole. Settle in.</p>
      </div>
      <div class="bc-hall-card bc-hall-card--violet">
        <div class="bc-hall-eyebrow bc-hall-eyebrow--violet">HALL THE SECOND</div>
        <h3 class="bc-hall-title bc-hall-title--violet">The Dark Ages Room</h3>
        <p class="bc-hall-text bc-hall-text--violet">Where alliances go to die. Party games, bluffing, betrayal, and loud accusations. No friendships guaranteed to survive.</p>
      </div>
    </div>
  </section>

  <!-- ===== FEATURED GAMES ===== -->
  <section class="bc-section">
    <div class="bc-section-row">
      <div>
        <div class="bc-eyebrow">ON THE TABLES</div>
        <h2 class="bc-h2">Featured Quests</h2>
      </div>
      <a href={withBase('/games/')} class="bc-see-all">SEE ALL GAMES &rarr;</a>
    </div>
    <div class="bc-featured-grid">
      {games.map((g) => (
        <a href={withBase(`/games/#${g.slug}`)} class="bc-featured-link" data-featured-item style="display:none;">
          <GameCard game={g} compact />
        </a>
      ))}
    </div>
  </section>

  <!-- ===== THE PARTY ===== -->
  <section class="bc-section bc-company">
    <div class="bc-eyebrow">TEN PLAYERS OF HONOUR</div>
    <h2 class="bc-h2 bc-h2--tight">Assemble the Party</h2>
    <div class="bc-avatar-row">
      {company.map((c) => (
        <a href={withBase(`/players/#${c.slug}`)} class="bc-avatar-link">
          <div class="bc-avatar">{c.initial}</div>
        </a>
      ))}
    </div>
    <div class="bc-company-link">
      <a href={withBase('/players/')}>MEET THE PARTY &rarr;</a>
    </div>
  </section>

  <!-- ===== CTA BAND ===== -->
  <section class="bc-cta-section">
    <div class="bc-cta-band">
      <div>
        <h2 class="bc-cta-title">Played something grand?</h2>
        <p class="bc-cta-text">Leave a review, or scrawl a secret upon the anonymous wall.</p>
      </div>
      <div class="bc-cta-buttons">
        <a href={withBase('/reviews/')} class="bc-btn bc-btn--solid">LEAVE A REVIEW</a>
        <a href={withBase('/wall/')} class="bc-btn bc-btn--outline">THE WALL</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .bc-hero {
    position: relative;
    overflow: hidden;
    background: var(--bc-hero-gradient);
    padding: 66px 28px 74px;
  }
  .bc-hero-40 {
    position: absolute;
    right: 0;
    bottom: -90px;
    font-family: 'Bangers', cursive;
    font-size: 440px;
    line-height: 0.8;
    color: rgba(119, 66, 220, 0.14);
    pointer-events: none;
    user-select: none;
  }
  .bc-hero-inner {
    max-width: var(--bc-max-width);
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }
  .bc-hero-eyebrow {
    font-family: 'Raleway', sans-serif;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 5px;
    color: #7fb4ff;
    margin-bottom: 10px;
  }
  .bc-nowrap {
    white-space: nowrap;
  }
  .bc-hero-title {
    margin: 10px 0 20px;
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 118px;
    line-height: 0.9;
    letter-spacing: 2px;
    transform: skewX(-4deg);
    text-shadow: 5px 6px 0 #12112e;
    white-space: nowrap;
  }
  .bc-hero-bailey {
    color: var(--bc-blue);
  }
  .bc-hero-con {
    color: var(--bc-gold);
  }
  .bc-hero-subtitle {
    font-family: 'Lato', sans-serif;
    font-size: 24px;
    line-height: 1.45;
    color: #d7dcff;
    max-width: 560px;
    margin: 0 0 30px;
  }
  .bc-hero-forty {
    font-weight: 900;
    color: var(--bc-gold);
  }
  .bc-badge-card {
    position: relative;
    background: var(--bc-page);
    border-radius: 14px;
    padding: 26px 30px;
    box-shadow: 0 24px 50px -16px rgba(0, 0, 0, 0.55);
    margin-bottom: 28px;
    max-width: 640px;
  }
  .bc-badge-punch {
    width: 44px;
    height: 5px;
    border-radius: 3px;
    background: #c8d1ec;
    margin: 0 auto 20px;
  }
  .bc-badge-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px 40px;
  }
  .bc-badge-label {
    font-family: 'Raleway', sans-serif;
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--bc-blue);
  }
  .bc-badge-value {
    font-family: 'Cinzel Decorative', serif;
    font-weight: 700;
    font-size: 22px;
    color: var(--bc-ink-strong);
  }
  .bc-hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .bc-btn {
    display: inline-block;
    padding: 16px 30px;
    font-family: 'Lato', sans-serif;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 1px;
    border-radius: 9px;
    border: 2px solid transparent;
  }
  .bc-btn--solid {
    background: var(--bc-blue);
    color: #fff;
    box-shadow: 0 10px 26px -6px rgba(77, 163, 255, 0.85);
  }
  .bc-btn--outline-hero {
    background: transparent;
    border-color: var(--bc-gold);
    color: var(--bc-gold);
  }
  .bc-btn--outline {
    background: transparent;
    border-color: var(--bc-gold);
    color: var(--bc-gold);
  }

  .bc-tale {
    max-width: 880px;
    margin: 0 auto;
    padding: 70px 28px 90px;
    text-align: center;
  }
  .bc-fleuron {
    color: var(--bc-blue-violet);
    font-size: 22px;
    margin-bottom: 14px;
  }
  .bc-eyebrow {
    font-family: 'Raleway', sans-serif;
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 6px;
    color: var(--bc-eyebrow);
    margin-bottom: 22px;
    text-transform: uppercase;
  }
  .bc-tale-text {
    font-family: 'Lato', sans-serif;
    font-size: 26px;
    line-height: 1.6;
    color: var(--bc-ink);
    margin: 0;
    text-wrap: pretty;
  }
  .bc-tale-highlight {
    color: #c79a1f;
    font-weight: 900;
  }

  .bc-section {
    max-width: var(--bc-max-width);
    margin: 0 auto;
    padding: 0 28px 70px;
  }
  .bc-section-head {
    text-align: center;
    margin-bottom: 34px;
  }
  .bc-section-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 28px;
  }
  .bc-h2 {
    margin: 0;
    font-family: 'Cinzel Decorative', serif;
    font-weight: 900;
    font-size: 42px;
    color: var(--bc-ink-strong);
  }
  .bc-h2--tight {
    margin-bottom: 24px;
  }
  .bc-see-all {
    font-family: 'Raleway', sans-serif;
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 2px;
    color: var(--bc-blue);
    border-bottom: 1px solid rgba(77, 163, 255, 0.5);
    padding-bottom: 2px;
  }

  .bc-halls-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .bc-hall-card {
    border-radius: 14px;
    padding: 32px 30px;
    position: relative;
    overflow: hidden;
  }
  .bc-hall-card--blue {
    border: 2px solid var(--bc-gold);
    background: var(--bc-card-blue);
    box-shadow: 6px 6px 0 var(--bc-blue-violet);
  }
  .bc-hall-card--violet {
    border: 2px solid #6a4fb0;
    background: var(--bc-card-purple);
    box-shadow: 6px 6px 0 var(--bc-blue);
  }
  .bc-hall-eyebrow {
    font-family: 'Raleway', sans-serif;
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 3px;
  }
  .bc-hall-eyebrow--blue {
    color: #bcd4ff;
  }
  .bc-hall-eyebrow--violet {
    color: var(--bc-epic);
  }
  .bc-hall-title {
    margin: 8px 0 12px;
    font-family: 'Lato', sans-serif;
    font-weight: 900;
    font-size: 28px;
    color: var(--bc-card-title);
  }
  .bc-hall-text {
    font-family: 'Lato', sans-serif;
    font-size: 16px;
    line-height: 1.55;
    margin: 0;
    color: var(--bc-card-desc);
  }

  .bc-featured-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .bc-featured-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .bc-company {
    text-align: center;
    padding-bottom: 24px;
  }
  .bc-avatar-row {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
  }
  .bc-avatar-link {
    display: inline-block;
    text-decoration: none;
  }
  .bc-avatar {
    width: 66px;
    height: 66px;
    border-radius: 50%;
    border: 2px solid var(--bc-gold);
    background: var(--bc-card-purple);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Lato', sans-serif;
    font-weight: 900;
    font-size: 20px;
    color: var(--bc-gold);
    margin: 0 6px 12px;
    box-shadow: 0 4px 12px rgba(31, 30, 95, 0.28);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }
  .bc-avatar-link:hover .bc-avatar {
    transform: scale(1.15);
    box-shadow: 0 6px 18px rgba(31, 30, 95, 0.4);
  }
  .bc-company-link {
    margin-top: 14px;
  }
  .bc-company-link a {
    font-family: 'Raleway', sans-serif;
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 2px;
    color: var(--bc-blue);
    border-bottom: 1px solid rgba(77, 163, 255, 0.5);
    padding-bottom: 2px;
  }

  .bc-cta-section {
    max-width: var(--bc-max-width);
    margin: 0 auto;
    padding: 0 28px 20px;
  }
  .bc-cta-band {
    border: 2px solid var(--bc-gold);
    border-radius: 14px;
    background: var(--bc-card-blueviolet);
    box-shadow: 6px 6px 0 var(--bc-deep-twilight);
    padding: 40px 36px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
  }
  .bc-cta-title {
    margin: 0 0 6px;
    font-family: 'Cinzel Decorative', serif;
    font-weight: 900;
    font-size: 34px;
    color: var(--bc-gold);
  }
  .bc-cta-text {
    margin: 0;
    font-family: 'Lato', sans-serif;
    font-size: 17px;
    color: #eae5fb;
  }
  .bc-cta-buttons {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .bc-hero-title {
      white-space: normal;
      font-size: 84px;
    }
    .bc-halls-grid {
      grid-template-columns: 1fr;
    }
    .bc-featured-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .bc-hero {
      padding: 44px 18px 48px;
    }
    .bc-hero-title {
      font-size: 58px;
    }
    .bc-hero-subtitle {
      font-size: 20px;
    }
    .bc-badge-card {
      padding: 20px 18px 18px;
    }
    .bc-badge-grid {
      gap: 16px 20px;
    }
    .bc-badge-value {
      font-size: 19px;
    }
    .bc-tale-text {
      font-size: 21px;
    }
    .bc-h2 {
      font-size: 32px;
    }
    .bc-hall-title {
      font-size: 25px;
    }
    .bc-featured-grid {
      grid-template-columns: 1fr;
    }
    .bc-cta-band {
      padding: 28px 22px;
    }
    .bc-cta-title {
      font-size: 27px;
    }
  }
</style>

<script>
  const items = Array.from(document.querySelectorAll<HTMLElement>('[data-featured-item]'));
  const FEATURED_COUNT = 4;
  const indices = items.map((_, i) => i);

  // Partial Fisher-Yates: only shuffle enough to isolate FEATURED_COUNT random picks.
  for (let i = indices.length - 1; i > 0 && i > indices.length - 1 - FEATURED_COUNT; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [indices[i], indices[j]] = [indices[j], indices[i]];
  }
  const chosen = new Set(indices.slice(-FEATURED_COUNT));

  items.forEach((el, i) => {
    if (chosen.has(i)) el.style.display = '';
  });
</script>
