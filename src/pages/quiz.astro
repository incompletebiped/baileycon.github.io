---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBanner from '../components/PageBanner.astro';
import { activeGuests } from '../data/guests';
import { withBase } from '../lib/url';

const rosterData = JSON.stringify(activeGuests.map((g) => ({ slug: g.slug, name: g.name })));
---

<BaseLayout title="The Stat Trial — BaileyCon" active="players">
  <PageBanner
    eyebrow="Prove Thy Worth"
    title="The Stat Trial"
    subtitle="Answer the call of the dice. Your card&rsquo;s art and title are safe — only your four stats are re-rolled."
  />

  <section class="bc-quiz-section">
    <!-- ===== PHASE 1: GATE ===== -->
    <div class="bc-panel" id="phase-gate">
      <h2 class="bc-panel-title">Identify Thyself</h2>
      <p class="bc-panel-text">Choose your character and enter the secret key you were given. This keeps mischief-makers from re-rolling stats that aren&rsquo;t theirs.</p>

      <label class="bc-field-label" for="gate-player">Your Character</label>
      <select id="gate-player" class="bc-field">
        <option value="">Choose a player…</option>
        {activeGuests.map((g) => (
          <option value={g.slug}>{g.name}</option>
        ))}
      </select>

      <label class="bc-field-label" for="gate-key">Secret Key</label>
      <input id="gate-key" class="bc-field" type="password" placeholder="Enter your secret key…" />

      <p class="bc-gate-error" id="gate-error" hidden></p>

      <button type="button" class="bc-btn" id="gate-submit">Begin the Trial</button>
    </div>

    <!-- ===== PHASE 2: QUIZ ===== -->
    <div class="bc-panel" id="phase-quiz" hidden>
      <div class="bc-quiz-progress-head">
        <span id="quiz-progress-label">Question 1 / 5</span>
      </div>
      <div class="bc-progress-track">
        <div class="bc-progress-fill" id="quiz-progress-fill"></div>
      </div>
      <p class="bc-quiz-prompt" id="quiz-prompt"></p>
      <div class="bc-quiz-options" id="quiz-options"></div>
    </div>

    <!-- ===== PHASE 3: RESULT ===== -->
    <div class="bc-panel" id="phase-result" hidden>
      <div class="bc-result-eyebrow" id="result-eyebrow"></div>
      <h2 class="bc-result-title" id="result-title"></h2>
      <p class="bc-result-flavor" id="result-flavor"></p>

      <div class="bc-result-stats">
        <div class="bc-result-stats-head">Your New Stats</div>
        <div id="result-stat-rows"></div>
      </div>

      <div class="bc-result-actions">
        <a href={withBase('/players/')} class="bc-btn" id="result-see-card">See My Card &rarr;</a>
        <button type="button" class="bc-btn bc-btn--outline" id="result-retake">Retake</button>
      </div>
    </div>
  </section>
</BaseLayout>

<script type="application/json" id="quiz-roster-data" set:html={rosterData}></script>

<style is:global>
  .bc-quiz-section {
    max-width: 620px;
    margin: 0 auto;
    padding: 0 28px 80px;
  }
  .bc-panel {
    background: var(--bc-panel);
    border: 1px solid var(--bc-border-gold);
    border-radius: 0;
    padding: 34px 32px;
  }
  .bc-panel-title {
    margin: 0 0 12px;
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 22px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--bc-gold);
  }
  .bc-panel-text {
    margin: 0 0 24px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.6);
  }
  .bc-field-label {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin: 18px 0 8px;
  }
  .bc-gate-error {
    margin: 14px 0 0;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    color: var(--bc-error);
  }
  .bc-btn {
    display: inline-block;
    background: var(--bc-gold);
    color: #1a0e02;
    border: 1.5px solid transparent;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 14px 26px;
    border-radius: 0;
    cursor: pointer;
    margin-top: 22px;
    transition: transform 0.15s ease;
    text-decoration: none;
  }
  .bc-btn:hover {
    color: #1a0e02;
    transform: skewX(-3deg) scale(1.03);
  }
  .bc-btn--outline {
    background: transparent;
    border-color: var(--bc-gold);
    color: var(--bc-gold);
  }

  .bc-quiz-progress-head {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 10px;
  }
  .bc-progress-track {
    height: 5px;
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.1);
    overflow: hidden;
    margin-bottom: 28px;
  }
  .bc-progress-fill {
    height: 100%;
    width: 20%;
    background: linear-gradient(90deg, var(--bc-blue), var(--bc-gold));
    transition: width 0.3s ease;
  }
  .bc-quiz-prompt {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-style: italic;
    font-size: 21px;
    color: #fff;
    margin: 0 0 22px;
    line-height: 1.4;
  }
  .bc-quiz-options {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .bc-quiz-option {
    text-align: left;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--bc-border-gold);
    border-radius: 0;
    color: rgba(255, 255, 255, 0.85);
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14.5px;
    line-height: 1.5;
    padding: 14px 16px;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }
  .bc-quiz-option:hover {
    border-color: var(--bc-border-gold-strong);
    background: rgba(255, 207, 92, 0.08);
  }

  .bc-result-eyebrow {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--bc-blue);
    margin-bottom: 10px;
  }
  .bc-result-title {
    margin: 0 0 10px;
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-style: italic;
    font-size: 28px;
    color: var(--bc-gold);
  }
  .bc-result-flavor {
    margin: 0 0 26px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.6);
  }
  .bc-result-stats {
    border-top: 1px solid var(--bc-border-gold);
    padding-top: 20px;
  }
  .bc-result-stats-head {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 12px;
  }
  .bc-result-stat-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
    padding: 6px 0;
  }
  .bc-result-stat-pips {
    color: var(--bc-gold);
    font-size: 15px;
    letter-spacing: 2px;
  }
  .bc-result-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  @media (max-width: 480px) {
    .bc-panel {
      padding: 26px 22px;
    }
  }
</style>

<script>
  import { supabase, supabaseConfigured } from '../lib/supabase';
  import { pickQuestions, statOrder, statLabels, classMap, scoreQuiz, type StatKey, type QuizQuestion } from '../data/quizQuestions';

  interface RosterEntry {
    slug: string;
    name: string;
  }

  const rosterEl = document.getElementById('quiz-roster-data');
  const roster: RosterEntry[] = rosterEl ? JSON.parse(rosterEl.textContent || '[]') : [];

  const gatePanel = document.getElementById('phase-gate');
  const quizPanel = document.getElementById('phase-quiz');
  const resultPanel = document.getElementById('phase-result');
  const playerSelect = document.getElementById('gate-player') as HTMLSelectElement | null;
  const keyInput = document.getElementById('gate-key') as HTMLInputElement | null;
  const gateError = document.getElementById('gate-error');
  const gateSubmit = document.getElementById('gate-submit');
  const progressLabel = document.getElementById('quiz-progress-label');
  const progressFill = document.getElementById('quiz-progress-fill');
  const promptEl = document.getElementById('quiz-prompt');
  const optionsEl = document.getElementById('quiz-options');
  const resultEyebrow = document.getElementById('result-eyebrow');
  const resultTitle = document.getElementById('result-title');
  const resultFlavor = document.getElementById('result-flavor');
  const resultRows = document.getElementById('result-stat-rows');
  const seeCardLink = document.getElementById('result-see-card') as HTMLAnchorElement | null;
  const retakeBtn = document.getElementById('result-retake');

  if (
    gatePanel && quizPanel && resultPanel && playerSelect && keyInput && gateError && gateSubmit &&
    progressLabel && progressFill && promptEl && optionsEl &&
    resultEyebrow && resultTitle && resultFlavor && resultRows && seeCardLink && retakeBtn
  ) {
    const playersBaseHref = seeCardLink.href;
    let pid = '';
    let quiz: QuizQuestion[] = [];
    let qi = 0;
    let points: Record<StatKey, number> = { str: 0, chs: 0, blf: 0, sta: 0 };

    function unlock() {
      const chosen = roster.find((r) => r.slug === playerSelect!.value);
      if (!chosen) {
        showError('Choose your character first.');
        return;
      }
      const expected = chosen.name.toLowerCase().replace(/\s+/g, '').split('').reverse().join('');
      const got = (keyInput!.value || '').toLowerCase().replace(/\s+/g, '');
      if (!got) {
        showError('Enter your secret key.');
        return;
      }
      if (got !== expected) {
        showError('That secret key does not match this character.');
        return;
      }

      pid = chosen.slug;
      points = { str: 0, chs: 0, blf: 0, sta: 0 };
      qi = 0;
      quiz = pickQuestions();
      gateError!.hidden = true;
      gatePanel!.hidden = true;
      quizPanel!.hidden = false;
      renderQuestion();
    }

    function showError(msg: string) {
      gateError!.textContent = msg;
      gateError!.hidden = false;
    }

    function renderQuestion() {
      const q = quiz[qi];
      progressLabel!.textContent = `Question ${qi + 1} / ${quiz.length}`;
      progressFill!.style.width = `${((qi + 1) / quiz.length) * 100}%`;
      promptEl!.textContent = q.prompt;
      optionsEl!.innerHTML = '';
      q.options.forEach((opt, i) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'bc-quiz-option';
        btn.textContent = opt.label;
        btn.addEventListener('click', () => answer(i));
        optionsEl!.append(btn);
      });
    }

    function answer(idx: number) {
      const opt = quiz[qi].options[idx];
      const next = { ...points };
      (Object.keys(opt.s) as StatKey[]).forEach((k) => {
        next[k] = (next[k] || 0) + (opt.s[k] || 0);
      });
      points = next;

      if (qi < quiz.length - 1) {
        qi++;
        renderQuestion();
      } else {
        finish();
      }
    }

    async function finish() {
      const stats = scoreQuiz(points);
      const top = statOrder.find((k) => stats[k] === 5)!;
      const cls = classMap[top];
      const chosen = roster.find((r) => r.slug === pid);

      resultEyebrow!.textContent = `The dice have spoken · ${chosen?.name || ''}`;
      resultTitle!.textContent = cls.title;
      resultFlavor!.textContent = cls.flavor;
      resultRows!.innerHTML = '';
      statOrder.forEach((k) => {
        const row = document.createElement('div');
        row.className = 'bc-result-stat-row';
        const label = document.createElement('span');
        label.textContent = statLabels[k];
        const pipsEl = document.createElement('span');
        pipsEl.className = 'bc-result-stat-pips';
        pipsEl.textContent = '◆'.repeat(stats[k]) + '◇'.repeat(5 - stats[k]);
        row.append(label, pipsEl);
        resultRows!.append(row);
      });
      seeCardLink!.href = `${playersBaseHref}#${pid}`;

      quizPanel!.hidden = true;
      resultPanel!.hidden = false;

      if (supabaseConfigured) {
        await supabase.from('player_stats').upsert({
          player_slug: pid,
          str: stats.str,
          chs: stats.chs,
          blf: stats.blf,
          sta: stats.sta,
          updated_at: new Date().toISOString(),
        });
      }
    }

    function retake() {
      qi = 0;
      points = { str: 0, chs: 0, blf: 0, sta: 0 };
      quiz = pickQuestions();
      resultPanel!.hidden = true;
      quizPanel!.hidden = false;
      renderQuestion();
    }

    gateSubmit.addEventListener('click', unlock);
    retakeBtn.addEventListener('click', retake);
  }
</script>
