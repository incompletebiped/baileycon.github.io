---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBanner from '../components/PageBanner.astro';

const rules = [
  {
    title: 'Record Thy Own Victory',
    body: "Every player logs their own wins on the Wins page — no proxies, no dungeon master filing on your behalf. The full ledger is public for anyone to see, so there's no slipping in a phantom win. Fib about a victory and the table will absolutely call thee out.",
  },
  {
    title: 'When a Game Crowns Many',
    body: "Some games send more than one player home victorious — Secret Hitler's whole winning faction, for instance. When that happens, every winning player records their own entry for that game. Each recorded win counts on its own toward the standings.",
  },
  {
    title: 'Champions of the Table',
    body: 'The podium on the Wins page ranks players by total points earned across every recorded win. Each game’s Win Value (shown on its card) is what gets added to your tally each time you claim victory.',
  },
  {
    title: 'Breaking a Tie',
    body: 'Same total points? Whoever notched more wins to get there takes the higher rank — quantity beats quality. Example: one player reaches 12 points from two 6-point victories, another reaches 12 points from six 2-point victories — the six-time victor ranks higher. Still tied after that? It comes down to a roll of the d20 at the table.',
  },
  {
    title: 'Played Something We Don’t Have Listed?',
    body: 'Choose "Game not listed" from the game dropdown on Record a Win, then name the game and set its Win Value by hand. It’ll show up in the ledger and count toward the standings just like any other game.',
  },
];
---

<BaseLayout title="Rules — BaileyCon" active="rules">
  <PageBanner
    eyebrow="THE LAW OF THE LAND"
    title="The Rules"
    subtitle="Everyone logs their own wins, ties break by the numbers, and the honor system keeps it fair."
  />

  <section class="bc-rules-section">
    <div class="bc-rules-list">
      {rules.map((r) => (
        <div class="bc-rule-card">
          <h2 class="bc-rule-title">{r.title}</h2>
          <p class="bc-rule-text">{r.body}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .bc-rules-section {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 28px 80px;
  }
  .bc-rules-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .bc-rule-card {
    border: 2px solid #6a4fb0;
    border-radius: 14px;
    background: var(--bc-card-purple);
    box-shadow: 6px 6px 0 var(--bc-blue);
    padding: 28px 30px;
  }
  .bc-rule-title {
    margin: 0 0 12px;
    font-family: 'Lato', sans-serif;
    font-weight: 900;
    font-size: 22px;
    color: var(--bc-card-title);
  }
  .bc-rule-text {
    margin: 0;
    font-family: 'Lato', sans-serif;
    font-size: 16px;
    line-height: 1.6;
    color: var(--bc-card-desc);
  }

  @media (max-width: 480px) {
    .bc-rule-card {
      padding: 22px 22px;
    }
    .bc-rule-title {
      font-size: 20px;
    }
  }
</style>
