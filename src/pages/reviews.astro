---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBanner from '../components/PageBanner.astro';
import StarRating from '../components/StarRating.astro';
import { games } from '../data/games';

const gameOptions = [...games.map((g) => g.name).sort((a, b) => a.localeCompare(b)), 'Something else entirely'];
---

<BaseLayout title="Reviews — BaileyCon" active="reviews">
  <PageBanner
    eyebrow="BaileyCon III"
    title="Reviews"
    subtitle="Played something legendary &mdash; or lost a friendship to it? Record thy verdict for posterity."
  />

  <section class="bc-split-2col">
    <!-- FORM -->
    <div class="bc-form-col">
      <h2 class="bc-form-title">Log a Review</h2>

      <label class="bc-label" for="review-game">Game</label>
      <select class="bc-field" id="review-game" style="margin-bottom:16px;">
        <option value="">Choose a game…</option>
        {gameOptions.map((g) => (
          <option value={g}>{g}</option>
        ))}
      </select>

      <label class="bc-label" for="review-name">Your Name</label>
      <input class="bc-field" type="text" id="review-name" placeholder="Who's reviewing?" style="margin-bottom:16px;" />

      <label class="bc-label">Rating</label>
      <div class="bc-rating-row">
        <StarRating inputId="review-stars" />
        <span class="bc-rating-count" id="rating-count">0 / 5</span>
      </div>

      <label class="bc-label" for="review-text">Review</label>
      <textarea class="bc-field" id="review-text" placeholder="Was it worth the win value? Would you play it again?" rows="4" style="resize:vertical;margin-bottom:20px;"></textarea>

      <button id="review-submit" class="bc-submit-btn" disabled>Submit Review</button>
      <p id="review-status" class="bc-status" hidden></p>
    </div>

    <!-- FEED -->
    <div class="bc-board-col">
      <div class="bc-list-head">
        <h2 class="bc-list-title">Review Feed</h2>
        <span id="review-count" class="bc-count">&hellip;</span>
      </div>
      <div id="review-list" class="bc-list">
        <p class="bc-loading">Fetching the feed&hellip;</p>
      </div>
    </div>
  </section>
</BaseLayout>

<template id="review-card-template">
  <div class="bc-review-card">
    <div class="bc-review-head">
      <span class="bc-review-game"></span>
      <span class="bc-review-stars"></span>
    </div>
    <p class="bc-review-quote"></p>
    <div class="bc-review-meta">
      <span class="bc-review-name"></span>
      <span class="bc-review-dot">&#9670;</span>
      <span class="bc-review-date"></span>
    </div>
  </div>
</template>

<style is:global>
  .bc-split-2col {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 28px 70px;
    display: grid;
    grid-template-columns: 38% 62%;
    gap: 0;
    min-height: calc(100vh - 400px);
  }
  .bc-form-col {
    border-right: 1px solid var(--bc-border-gold);
    padding: 8px 36px 40px 8px;
  }
  .bc-board-col {
    padding: 8px 8px 40px 36px;
  }
  .bc-form-title {
    margin: 0 0 24px;
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 24px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--bc-gold);
  }
  .bc-label {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1.5px;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 8px;
    text-transform: uppercase;
  }
  .bc-rating-row {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 18px;
  }
  .bc-rating-count {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.5);
  }
  .bc-submit-btn {
    width: 100%;
    border: 1.5px solid var(--bc-gold);
    border-radius: 0;
    padding: 15px;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: not-allowed;
    color: rgba(255, 207, 92, 0.35);
    background: transparent;
    opacity: 0.4;
    transition: opacity 0.15s;
  }
  .bc-submit-btn:not(:disabled) {
    cursor: pointer;
    color: #1a0e02;
    background: var(--bc-gold);
    opacity: 1;
  }
  .bc-status {
    margin: 12px 0 0;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 12px;
    color: var(--bc-blue);
    text-align: center;
  }
  .bc-status.is-error {
    color: var(--bc-error);
  }

  .bc-list-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 24px;
  }
  .bc-list-title {
    margin: 0;
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 24px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #fff;
  }
  .bc-count {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 1px;
    color: rgba(255, 255, 255, 0.35);
  }
  .bc-list {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .bc-loading {
    font-family: 'Space Grotesk', sans-serif;
    color: rgba(255, 255, 255, 0.4);
  }
  .bc-review-card {
    border: 1px solid var(--bc-border-gold);
    border-radius: 0;
    background: var(--bc-panel);
    padding: 22px 24px;
  }
  .bc-review-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }
  .bc-review-game {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 12.5px;
    color: #1a0e02;
    background: var(--bc-gold);
    padding: 5px 14px;
    border-radius: 20px;
    max-width: 65%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .bc-review-stars {
    font-size: 16px;
    letter-spacing: 2px;
    color: var(--bc-gold);
    flex: none;
  }
  .bc-review-quote {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 17px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 0 14px;
  }
  .bc-review-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.5);
  }
  .bc-review-dot {
    color: var(--bc-gold);
    font-size: 8px;
  }
  .bc-empty-feed {
    text-align: center;
    padding: 40px 0;
  }
  .bc-empty-glyph {
    font-size: 30px;
    color: var(--bc-gold);
    display: block;
    margin-bottom: 10px;
  }

  @media (max-width: 760px) {
    .bc-split-2col {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    .bc-form-col {
      border-right: none;
      border-bottom: 1px solid var(--bc-border-gold);
      padding: 8px 8px 30px;
    }
    .bc-board-col {
      padding: 30px 8px 40px;
    }
  }
</style>

<script>
  import { supabase, supabaseConfigured } from '../lib/supabase';

  interface ReviewRow {
    id: number;
    game: string;
    name: string;
    stars: number;
    body: string;
    created_at: string;
  }

  const gameSelect = document.getElementById('review-game') as HTMLSelectElement;
  const nameInput = document.getElementById('review-name') as HTMLInputElement;
  const textInput = document.getElementById('review-text') as HTMLTextAreaElement;
  const starsInput = document.getElementById('review-stars') as HTMLInputElement;
  const ratingCount = document.getElementById('rating-count') as HTMLSpanElement;
  const submitBtn = document.getElementById('review-submit') as HTMLButtonElement;
  const statusEl = document.getElementById('review-status') as HTMLParagraphElement;
  const listEl = document.getElementById('review-list') as HTMLDivElement;
  const countEl = document.getElementById('review-count') as HTMLSpanElement;
  const template = document.getElementById('review-card-template') as HTMLTemplateElement;

  function starsStr(n: number) {
    return '★'.repeat(n) + '☆'.repeat(5 - n);
  }

  function formatDate(iso: string) {
    const d = new Date(iso);
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }

  function renderList(rows: ReviewRow[]) {
    listEl.innerHTML = '';
    countEl.textContent = `${rows.length} ${rows.length === 1 ? 'review' : 'reviews'}`;
    if (!rows.length) {
      const wrap = document.createElement('div');
      wrap.className = 'bc-empty-feed';
      wrap.innerHTML = '<span class="bc-empty-glyph">&#10022;</span><p class="bc-loading">No reviews yet — be the first.</p>';
      listEl.appendChild(wrap);
      return;
    }
    for (const r of rows) {
      const node = template.content.cloneNode(true) as DocumentFragment;
      (node.querySelector('.bc-review-game') as HTMLElement).textContent = r.game;
      (node.querySelector('.bc-review-stars') as HTMLElement).textContent = starsStr(r.stars);
      (node.querySelector('.bc-review-quote') as HTMLElement).textContent = `“${r.body}”`;
      (node.querySelector('.bc-review-name') as HTMLElement).textContent = r.name;
      (node.querySelector('.bc-review-date') as HTMLElement).textContent = formatDate(r.created_at);
      listEl.appendChild(node);
    }
  }

  function updateSubmitState() {
    const ok = Boolean(gameSelect.value && Number(starsInput.value) >= 1 && textInput.value.trim());
    submitBtn.disabled = !ok;
  }

  starsInput.addEventListener('change', () => {
    ratingCount.textContent = `${starsInput.value} / 5`;
    updateSubmitState();
  });
  [gameSelect, textInput].forEach((el) => el.addEventListener('input', updateSubmitState));
  gameSelect.addEventListener('change', updateSubmitState);

  async function loadReviews() {
    if (!supabaseConfigured) {
      listEl.innerHTML = '';
      const p = document.createElement('p');
      p.className = 'bc-loading';
      p.textContent = 'Reviews backend is not configured yet — ask the host to finish Supabase setup.';
      listEl.appendChild(p);
      countEl.textContent = '0 reviews';
      return;
    }
    const { data, error } = await supabase
      .from('reviews')
      .select('*')
      .order('created_at', { ascending: false });
    if (error) {
      listEl.innerHTML = `<p class="bc-loading">Could not load reviews (${error.message}).</p>`;
      return;
    }
    renderList((data as ReviewRow[]) || []);
  }

  async function submitReview() {
    const game = gameSelect.value;
    const name = nameInput.value.trim() || 'A mysterious traveler';
    const stars = Number(starsInput.value);
    const body = textInput.value.trim();
    if (!game || stars < 1 || !body) return;

    submitBtn.disabled = true;
    statusEl.hidden = true;
    statusEl.classList.remove('is-error');

    const { error } = await supabase.from('reviews').insert({ game, name, stars, body });
    if (error) {
      statusEl.textContent = `Could not post review (${error.message}).`;
      statusEl.classList.add('is-error');
      statusEl.hidden = false;
      updateSubmitState();
      return;
    }

    gameSelect.value = '';
    nameInput.value = '';
    textInput.value = '';
    starsInput.value = '0';
    starsInput.dispatchEvent(new Event('change'));
    document.querySelectorAll('.bc-star-btn').forEach((btn) => btn.classList.remove('is-on'));
    statusEl.textContent = '✓ Review posted!';
    statusEl.hidden = false;
    setTimeout(() => {
      statusEl.hidden = true;
    }, 3000);
    updateSubmitState();
    await loadReviews();
  }

  submitBtn.addEventListener('click', submitReview);

  updateSubmitState();
  loadReviews();
</script>
