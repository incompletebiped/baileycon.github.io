---
import BaseLayout from '../layouts/BaseLayout.astro';
import GameCard from '../components/GameCard.astro';
import { games, withDisplay } from '../data/games';
import { withBase } from '../lib/url';

const displayGames = games.map(withDisplay);
const slugsData = JSON.stringify(displayGames.map((g) => ({ slug: g.slug, hall: g.hall, hallColor: g.hallColor })));
---

<BaseLayout title="The Games — BaileyCon" active="games">
  <div class="bc-games-main">
    <div class="bc-backdrop">
      <div class="bc-backdrop-blur">
        <img class="bc-backdrop-img" id="backdrop-img" src={withBase(`/images/games/${displayGames[0].slug}.jpg`)} alt="" />
      </div>
      <div
        class="bc-backdrop-tint"
        id="backdrop-tint"
        style={`background:radial-gradient(ellipse at 72% 45%, ${displayGames[0].hallColor}33 0%, ${displayGames[0].hallColor}08 42%, transparent 62%), radial-gradient(ellipse at 8% 72%, rgba(46,33,102,0.55) 0%, transparent 52%), radial-gradient(ellipse at 92% 8%, rgba(8,6,20,0.75) 0%, transparent 45%);`}
      ></div>
    </div>

    <svg class="bc-stars" viewBox="0 0 1400 800" preserveAspectRatio="xMidYMid slice">
      <path d="M90 90 L92 98 L100 100 L92 102 L90 110 L88 102 L80 100 L88 98 Z" fill="#ffcf5c" opacity="0.3" />
      <path d="M1280 70 L1281.5 76 L1287 77.5 L1281.5 79 L1280 85 L1278.5 79 L1273 77.5 L1278.5 76 Z" fill="#4da3ff" opacity="0.35" />
      <path d="M1340 350 L1341 354 L1345 355 L1341 356 L1340 360 L1339 356 L1335 355 L1339 354 Z" fill="#ffcf5c" opacity="0.28" />
      <path d="M60 550 L61.5 556 L67 557.5 L61.5 559 L60 565 L58.5 559 L53 557.5 L58.5 556 Z" fill="#4da3ff" opacity="0.28" />
      <circle cx="700" cy="45" r="1.5" fill="#fff" opacity="0.2" />
      <circle cx="250" cy="220" r="1" fill="#ffcf5c" opacity="0.18" />
      <circle cx="1050" cy="180" r="1" fill="#4da3ff" opacity="0.2" />
      <circle cx="450" cy="680" r="1.5" fill="#fff" opacity="0.14" />
      <circle cx="1200" cy="580" r="1" fill="#ffcf5c" opacity="0.18" />
      <circle cx="150" cy="380" r="1" fill="#4da3ff" opacity="0.15" />
    </svg>

    <div class="bc-hero-wrap" id="hero-wrap">
      {displayGames.map((g, i) => <GameCard game={g} idx={i} />)}
    </div>

    <div class="bc-carousel-section">
      <div class="bc-carousel-head">
        <span>All Games</span>
        <span class="bc-carousel-count" id="carousel-count">{games.length} Titles</span>
      </div>
      <div class="bc-carousel" id="carousel">
        {displayGames.map((g, i) => (
          <button type="button" class="bc-thumb" data-thumb data-idx={i} data-slug={g.slug}>
            <div class="bc-thumb-art">
              <div class="bc-thumb-placeholder"></div>
              <img src={withBase(`/images/games/${g.slug}.jpg`)} alt="" onerror="this.style.display='none'" loading="lazy" />
              <span class="bc-thumb-played" data-thumb-played hidden>&#10003;</span>
            </div>
            <div class="bc-thumb-top" style={`background:${g.hallColor};`}></div>
            <div class="bc-thumb-text">
              <div class="bc-thumb-name">{g.name}</div>
              <div class="bc-thumb-hall" style={`color:${g.hallColor};`}>{g.hall}</div>
            </div>
          </button>
        ))}
      </div>
      <p class="bc-games-note">&hellip;and many more to be added. Got one to bring? Tell the host!</p>
    </div>
  </div>
</BaseLayout>

<script type="application/json" id="games-slugs-data" set:html={slugsData}></script>

<style>
  .bc-games-main {
    position: relative;
    min-height: calc(100vh - 52px);
    display: flex;
    flex-direction: column;
    background: #06040f;
    overflow: hidden;
  }
  .bc-backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  /* Dual Kawase blur: a tiny render of the box art, scaled way up. The
   * upscale blurs fine detail while keeping big color blocks/shapes intact
   * — a real CSS blur() over the full-size image just washes it to gray. */
  .bc-backdrop-blur {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 120px;
    height: 84px;
    transform: translate(-50%, -50%) scale(18);
    transform-origin: center;
    filter: brightness(0.16) saturate(0.25);
  }
  .bc-backdrop-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bc-backdrop-tint {
    position: absolute;
    inset: 0;
    transition: background 0.4s ease;
  }
  .bc-stars {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }
  .bc-hero-wrap {
    position: relative;
    z-index: 2;
    flex: 1;
    min-height: 0;
  }

  .bc-carousel-section {
    position: relative;
    z-index: 2;
    flex-shrink: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-top: 14px;
  }
  .bc-carousel-head {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0 64px 10px;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 7.5px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.25);
  }
  .bc-carousel-count {
    color: var(--bc-gold);
    opacity: 0.8;
  }
  .bc-carousel {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    padding: 4px 64px 28px;
    scrollbar-width: thin;
  }
  .bc-thumb {
    flex: none;
    width: 150px;
    background: var(--bc-panel);
    border: 1px solid var(--bc-border-gold);
    border-radius: 0;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    transition: transform 0.15s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.15s, border-color 0.15s;
    text-align: left;
  }
  .bc-thumb:hover {
    transform: translateY(-8px) skewX(-2deg) rotate(-0.5deg);
    box-shadow: 5px 5px 0 rgba(255, 207, 92, 0.4);
    border-color: rgba(255, 207, 92, 0.55);
  }
  .bc-thumb.is-active {
    border-color: var(--bc-gold);
  }
  .bc-thumb-art {
    position: relative;
    aspect-ratio: 150 / 96;
    overflow: hidden;
    background: #09071a;
  }
  .bc-thumb-placeholder {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0 8px, rgba(255, 255, 255, 0.03) 8px 16px);
  }
  .bc-thumb-art img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .bc-thumb-played[hidden] {
    display: none;
  }
  .bc-thumb-played {
    position: absolute;
    top: 5px;
    right: 5px;
    width: 19px;
    height: 19px;
    border-radius: 0;
    background: rgba(6, 4, 15, 0.82);
    border: 1px solid rgba(77, 163, 255, 0.6);
    color: var(--bc-blue);
    font-size: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
  }
  .bc-thumb-top {
    height: 2px;
  }
  .bc-thumb-text {
    padding: 8px 9px 10px;
  }
  .bc-thumb-name {
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 11.5px;
    color: #fff;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .bc-thumb-hall {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 7.5px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-top: 3px;
    opacity: 0.75;
  }
  .bc-games-note {
    text-align: center;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.35);
    margin: 20px 0 0;
    padding-bottom: 30px;
  }

  @media (max-width: 760px) {
    .bc-carousel-head {
      padding: 0 20px 10px;
    }
    .bc-carousel {
      padding: 4px 20px 24px;
    }
  }
</style>

<script>
  import { supabase, supabaseConfigured } from '../lib/supabase';
  import { withBase } from '../lib/url';

  interface GameMeta {
    slug: string;
    hall: string;
    hallColor: string;
  }

  const metaEl = document.getElementById('games-slugs-data');
  const gamesMeta: GameMeta[] = metaEl ? JSON.parse(metaEl.textContent || '[]') : [];

  const heroWrap = document.getElementById('hero-wrap');
  const carousel = document.getElementById('carousel');
  const backdropImg = document.getElementById('backdrop-img') as HTMLImageElement | null;
  const backdropTint = document.getElementById('backdrop-tint');

  if (heroWrap && carousel && backdropImg && backdropTint && gamesMeta.length) {
    const heroes = Array.from(heroWrap.querySelectorAll<HTMLElement>('[data-hero]'));
    const thumbs = Array.from(carousel.querySelectorAll<HTMLElement>('[data-thumb]'));
    let selected = 0;
    let played: Record<string, boolean> = {};
    let isSpinning = false;
    let spinTimer: number | undefined;

    function updatePlayedUI() {
      heroes.forEach((hero) => {
        const slug = hero.dataset.slug || '';
        const isPlayed = !!played[slug];
        const badge = hero.querySelector<HTMLElement>('[data-played-badge]');
        const box = hero.querySelector<HTMLElement>('[data-played-box]');
        const label = hero.querySelector<HTMLElement>('[data-played-label]');
        if (badge) badge.hidden = !isPlayed;
        if (box) {
          box.style.background = isPlayed ? '#4da3ff' : 'transparent';
          box.style.borderColor = isPlayed ? '#4da3ff' : 'rgba(255,255,255,0.35)';
          box.textContent = isPlayed ? '✓' : '';
        }
        if (label) label.style.color = isPlayed ? '#4da3ff' : 'rgba(255,255,255,0.5)';
      });
      thumbs.forEach((thumb) => {
        const slug = thumb.dataset.slug || '';
        const mark = thumb.querySelector<HTMLElement>('[data-thumb-played]');
        if (mark) mark.hidden = !played[slug];
      });
    }

    function render() {
      heroes.forEach((hero, i) => {
        hero.hidden = i !== selected;
      });
      thumbs.forEach((thumb, i) => {
        thumb.classList.toggle('is-active', i === selected);
      });

      const meta = gamesMeta[selected];
      backdropImg.src = withBase(`/images/games/${meta.slug}.jpg`);
      backdropTint.style.background = [
        `radial-gradient(ellipse at 72% 45%, ${meta.hallColor}33 0%, ${meta.hallColor}08 42%, transparent 62%)`,
        'radial-gradient(ellipse at 8% 72%, rgba(46,33,102,0.55) 0%, transparent 52%)',
        'radial-gradient(ellipse at 92% 8%, rgba(8,6,20,0.75) 0%, transparent 45%)',
      ].join(', ');

      const activeThumb = thumbs[selected];
      if (activeThumb) {
        const target = activeThumb.offsetLeft - carousel!.clientWidth / 2 + activeThumb.clientWidth / 2;
        carousel!.scrollTo({ left: Math.max(0, target), behavior: 'smooth' });
      }
    }

    function select(idx: number, updateHash = true) {
      selected = idx;
      render();
      if (updateHash) history.replaceState(null, '', `#${gamesMeta[idx].slug}`);
    }

    function spinTo(target: number) {
      if (isSpinning) return;
      isSpinning = true;
      document.querySelectorAll<HTMLElement>('[data-randomize-label]').forEach((el) => (el.textContent = '⏳ Selecting…'));
      const delays = [45, 48, 52, 60, 72, 90, 115, 148, 190, 245, 320];
      const steps = delays.map(() => Math.floor(Math.random() * gamesMeta.length));
      steps.push(target);
      let i = 0;
      const tick = () => {
        select(steps[i], false);
        i++;
        if (i < steps.length) {
          spinTimer = window.setTimeout(tick, delays[i - 1] ?? 320);
        } else {
          spinTimer = window.setTimeout(() => {
            isSpinning = false;
            document.querySelectorAll<HTMLElement>('[data-randomize-label]').forEach((el) => (el.textContent = 'Randomize'));
            history.replaceState(null, '', `#${gamesMeta[target].slug}`);
          }, 500);
        }
      };
      spinTimer = window.setTimeout(tick, 40);
    }

    function randomize() {
      if (isSpinning) return;
      const allIdx = gamesMeta.map((_, i) => i);
      const fresh = allIdx.filter((i) => !played[gamesMeta[i].slug] && i !== selected);
      const pool = fresh.length ? fresh : allIdx.filter((i) => i !== selected);
      if (!pool.length) return;
      const target = pool[Math.floor(Math.random() * pool.length)];
      spinTo(target);
    }

    async function togglePlayed(slug: string) {
      const next = !played[slug];
      played = { ...played, [slug]: next };
      updatePlayedUI();
      if (!supabaseConfigured) return;
      await supabase.from('games_played').upsert({ game_slug: slug, played: next, updated_at: new Date().toISOString() });
    }

    async function loadPlayed() {
      if (!supabaseConfigured) return;
      const { data, error } = await supabase.from('games_played').select('game_slug, played');
      if (error || !data) return;
      const next: Record<string, boolean> = {};
      for (const row of data as { game_slug: string; played: boolean }[]) {
        if (row.played) next[row.game_slug] = true;
      }
      played = next;
      updatePlayedUI();
    }

    thumbs.forEach((thumb, i) => {
      thumb.addEventListener('click', () => select(i));
    });

    heroWrap.querySelectorAll<HTMLElement>('[data-randomize-btn]').forEach((btn) => {
      btn.addEventListener('click', randomize);
    });
    heroWrap.querySelectorAll<HTMLElement>('[data-toggle-played]').forEach((toggle) => {
      toggle.addEventListener('click', () => {
        const hero = toggle.closest<HTMLElement>('[data-hero]');
        const slug = hero?.dataset.slug;
        if (slug) togglePlayed(slug);
      });
    });

    const initialSlug = window.location.hash.slice(1);
    const initialIdx = initialSlug ? gamesMeta.findIndex((g) => g.slug === initialSlug) : 0;
    select(initialIdx >= 0 ? initialIdx : 0, false);
    loadPlayed();
  }
</script>

<script>
  import { supabase, supabaseConfigured } from '../lib/supabase';

  interface ReviewRatingRow {
    game: string;
    stars: number;
  }

  async function loadRatings() {
    if (!supabaseConfigured) return;

    const { data, error } = await supabase.from('reviews').select('game, stars');
    if (error || !data) return;

    const totals = new Map<string, { sum: number; count: number }>();
    for (const row of data as ReviewRatingRow[]) {
      const entry = totals.get(row.game) || { sum: 0, count: 0 };
      entry.sum += row.stars;
      entry.count += 1;
      totals.set(row.game, entry);
    }

    document.querySelectorAll<HTMLElement>('[data-hero]').forEach((hero) => {
      const nameEl = hero.querySelector<HTMLElement>('.bc-hero-title');
      const name = nameEl?.textContent || '';
      const entry = totals.get(name);
      if (!entry) return;

      const slot = hero.querySelector<HTMLElement>('[data-rating-slot]');
      if (!slot) return;

      const avg = (entry.sum / entry.count).toFixed(1);
      const reviewWord = entry.count === 1 ? 'review' : 'reviews';
      slot.textContent = `★ ${avg} · ${entry.count} ${reviewWord}`;
      slot.hidden = false;
    });
  }

  loadRatings();
</script>
