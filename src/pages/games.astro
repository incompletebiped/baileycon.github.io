---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBanner from '../components/PageBanner.astro';
import GameCard from '../components/GameCard.astro';
import Crest from '../components/Crest.astro';
import { games, withDisplay } from '../data/games';

const displayGames = games.map(withDisplay);
const rollerData = JSON.stringify(games.map((g) => ({ slug: g.slug, name: g.name })));
---

<BaseLayout title="The Games — BaileyCon" active="games">
  <PageBanner
    eyebrow="THE ARMORY"
    title="The Games"
    subtitle="A growing muster of the finest board & card games the tavern can hold. More shall be added as the day draws near."
  />

  <section class="bc-legend">
    <span>COMPLEXITY:</span>
    <span><span class="bc-legend-gold">&#9670;</span>&#9671;&#9671; LIGHT</span>
    <span><span class="bc-legend-gold">&#9670;&#9670;</span>&#9671; MEDIUM</span>
    <span><span class="bc-legend-gold">&#9670;&#9670;&#9670;</span> HEAVY</span>
  </section>

  <section class="bc-controls">
    <label class="bc-control">
      <span class="bc-control-label">SORT BY</span>
      <select id="games-sort" class="bc-control-select">
        <option value="default">Collection Order</option>
        <option value="name">Name (A&ndash;Z)</option>
        <option value="time">Time (Quickest First)</option>
        <option value="players">Players (Fewest First)</option>
        <option value="weight">Complexity (Lightest First)</option>
      </select>
    </label>
    <label class="bc-control">
      <span class="bc-control-label">PARTY SIZE</span>
      <select id="games-players-filter" class="bc-control-select">
        <option value="any">Any</option>
        <option value="1">1 player</option>
        <option value="2">2 players</option>
        <option value="3">3 players</option>
        <option value="4">4 players</option>
        <option value="5">5 players</option>
        <option value="6">6 players</option>
        <option value="7">7 players</option>
        <option value="8">8+ players</option>
      </select>
    </label>
  </section>

  <section class="bc-games-section">
    <div class="bc-games-grid" id="games-grid">
      {displayGames.map((g) => (
        <GameCard game={g} />
      ))}
    </div>
    <p class="bc-games-empty" id="games-empty" hidden>No games fit that party size &mdash; try a different number.</p>
    <p class="bc-games-note">&hellip;and many more to be added. Got one to bring? Tell the host!</p>
  </section>

  <!-- ===== DICE ROLLER ===== -->
  <section class="bc-roller-section">
    <div class="bc-roller-card">
      <div class="bc-eyebrow-roller">CAN&rsquo;T DECIDE?</div>
      <h2 class="bc-roller-title">Let the Dice Choose</h2>
      <button type="button" id="dice-roll-btn" class="bc-dice-btn" aria-label="Roll the dice to pick a random game">
        <div class="bc-dice-visual" id="dice-visual"><Crest size={78} /></div>
      </button>
      <p class="bc-roller-hint">Tap the die to summon tonight&rsquo;s game.</p>
      <p id="dice-result" class="bc-dice-result" aria-live="polite">&nbsp;</p>
    </div>
  </section>
</BaseLayout>

<script>
  interface CardData {
    el: HTMLElement;
    name: string;
    playersMin: number;
    playersMax: number;
    timeMin: number;
    weight: number;
  }

  const grid = document.getElementById('games-grid');
  const emptyMsg = document.getElementById('games-empty');
  const sortSelect = document.getElementById('games-sort') as HTMLSelectElement | null;
  const playersSelect = document.getElementById('games-players-filter') as HTMLSelectElement | null;

  if (grid && sortSelect && playersSelect) {
    const cards: CardData[] = Array.from(grid.querySelectorAll<HTMLElement>('.bc-game-card')).map((el) => ({
      el,
      name: el.dataset.name || '',
      playersMin: Number(el.dataset.playersMin) || 0,
      playersMax: Number(el.dataset.playersMax) || 99,
      timeMin: Number(el.dataset.timeMin) || 0,
      weight: Number(el.dataset.weight) || 1,
    }));

    function applyControls() {
      const playerFilter = playersSelect!.value;
      const sortBy = sortSelect!.value;

      const visible =
        playerFilter === 'any'
          ? cards
          : cards.filter((c) => Number(playerFilter) >= c.playersMin && Number(playerFilter) <= c.playersMax);
      const visibleSet = new Set(visible);

      cards.forEach((c) => {
        c.el.style.display = visibleSet.has(c) ? '' : 'none';
      });

      const ordered = cards.slice();
      if (sortBy === 'name') ordered.sort((a, b) => a.name.localeCompare(b.name));
      else if (sortBy === 'time') ordered.sort((a, b) => a.timeMin - b.timeMin);
      else if (sortBy === 'players') ordered.sort((a, b) => a.playersMin - b.playersMin);
      else if (sortBy === 'weight') ordered.sort((a, b) => a.weight - b.weight);

      ordered.forEach((c) => grid!.appendChild(c.el));

      if (emptyMsg) emptyMsg.hidden = visible.length > 0;
    }

    sortSelect.addEventListener('change', applyControls);
    playersSelect.addEventListener('change', applyControls);
  }
</script>

<script>
  import { supabase, supabaseConfigured } from '../lib/supabase';

  interface ReviewRatingRow {
    game: string;
    stars: number;
  }

  async function loadRatings() {
    if (!supabaseConfigured) return;

    const { data, error } = await supabase.from('reviews').select('game, stars');
    if (error || !data) return;

    const totals = new Map<string, { sum: number; count: number }>();
    for (const row of data as ReviewRatingRow[]) {
      const entry = totals.get(row.game) || { sum: 0, count: 0 };
      entry.sum += row.stars;
      entry.count += 1;
      totals.set(row.game, entry);
    }

    document.querySelectorAll<HTMLElement>('.bc-game-card').forEach((card) => {
      const name = card.dataset.name || '';
      const entry = totals.get(name);
      if (!entry) return;

      const slot = card.querySelector<HTMLElement>('[data-rating-slot]');
      if (!slot) return;

      const avg = (entry.sum / entry.count).toFixed(1);
      const reviewWord = entry.count === 1 ? 'review' : 'reviews';
      slot.textContent = `★ ${avg} · ${entry.count} ${reviewWord}`;
      slot.hidden = false;
    });
  }

  loadRatings();
</script>

<script type="application/json" id="roller-games-data" set:html={rollerData}></script>
<script>
  interface RollerGame {
    slug: string;
    name: string;
  }

  const dataEl = document.getElementById('roller-games-data');
  const rollerGames: RollerGame[] = dataEl ? JSON.parse(dataEl.textContent || '[]') : [];

  const btn = document.getElementById('dice-roll-btn') as HTMLButtonElement | null;
  const visual = document.getElementById('dice-visual') as HTMLDivElement | null;
  const resultEl = document.getElementById('dice-result') as HTMLParagraphElement | null;

  let rolling = false;

  function rollDice() {
    if (!btn || !visual || !resultEl || rolling || !rollerGames.length) return;
    rolling = true;
    btn.disabled = true;

    visual.classList.remove('is-rolling');
    // Force reflow so the animation restarts on repeated clicks.
    void visual.offsetWidth;
    visual.classList.add('is-rolling');

    setTimeout(() => {
      const pick = rollerGames[Math.floor(Math.random() * rollerGames.length)];

      resultEl.textContent = '';
      resultEl.append("Tonight's fate: ");
      const link = document.createElement('a');
      link.href = `#${pick.slug}`;
      link.textContent = pick.name;
      resultEl.append(link);

      const target = document.getElementById(pick.slug);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        target.classList.remove('bc-highlight');
        void (target as HTMLElement).offsetWidth;
        target.classList.add('bc-highlight');
        setTimeout(() => target.classList.remove('bc-highlight'), 1700);
      }

      visual.classList.remove('is-rolling');
      rolling = false;
      btn.disabled = false;
    }, 700);
  }

  btn?.addEventListener('click', rollDice);
</script>

<style>
  .bc-legend {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 28px 24px;
    display: flex;
    justify-content: center;
    gap: 22px;
    flex-wrap: wrap;
    font-family: 'Raleway', sans-serif;
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 2px;
    color: var(--bc-faint);
  }
  .bc-legend-gold {
    color: var(--bc-gold);
  }
  .bc-controls {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 28px 44px;
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }
  .bc-control {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .bc-control-label {
    font-family: 'Raleway', sans-serif;
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 2px;
    color: var(--bc-faint);
    white-space: nowrap;
  }
  .bc-control-select {
    background: #ffffff;
    border: 1.5px solid #cdd6ee;
    border-radius: 8px;
    color: var(--bc-ink-strong);
    font-family: 'Lato', sans-serif;
    font-size: 15px;
    padding: 11px 16px;
    outline: none;
    cursor: pointer;
    transition: outline-color 0.12s;
  }
  .bc-control-select:focus {
    outline: 2px solid var(--bc-blue);
    outline-offset: 1px;
  }
  .bc-games-section {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 28px 40px;
  }
  .bc-games-empty {
    text-align: center;
    font-family: 'Lato', sans-serif;
    font-size: 16px;
    color: var(--bc-muted);
    padding: 30px 0;
  }
  .bc-games-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  .bc-games-note {
    text-align: center;
    font-family: 'Lato', sans-serif;
    font-size: 16px;
    color: var(--bc-muted);
    margin-top: 44px;
  }

  @media (max-width: 980px) {
    .bc-games-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 620px) {
    .bc-games-grid {
      grid-template-columns: 1fr;
    }
  }

  .bc-roller-section {
    max-width: 600px;
    margin: 0 auto;
    padding: 0 28px 72px;
    text-align: center;
  }
  .bc-roller-card {
    border: 2px solid var(--bc-gold);
    border-radius: 14px;
    background: var(--bc-card-blueviolet);
    padding: 34px 28px 30px;
    box-shadow: 6px 6px 0 var(--bc-deep-twilight);
  }
  .bc-eyebrow-roller {
    font-family: 'Raleway', sans-serif;
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 5px;
    color: #cbb8ff;
    margin-bottom: 10px;
    text-transform: uppercase;
  }
  .bc-roller-title {
    margin: 0 0 20px;
    font-family: 'Lato', sans-serif;
    font-weight: 900;
    font-size: 30px;
    color: var(--bc-gold);
  }
  .bc-dice-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }
  .bc-dice-visual {
    display: inline-flex;
    transition: transform 0.18s ease;
  }
  .bc-dice-btn:hover .bc-dice-visual:not(.is-rolling) {
    transform: scale(1.1);
  }
  .bc-dice-visual.is-rolling {
    animation: bc-dice-spin 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes bc-dice-spin {
    0% {
      transform: rotate(0deg) scale(1);
    }
    35% {
      transform: rotate(230deg) scale(1.18);
    }
    65% {
      transform: rotate(500deg) scale(0.92);
    }
    100% {
      transform: rotate(720deg) scale(1);
    }
  }
  .bc-roller-hint {
    margin: 14px 0 0;
    font-family: 'Lato', sans-serif;
    font-size: 14px;
    color: #e2d6ff;
  }
  .bc-dice-result {
    margin: 14px 0 0;
    min-height: 24px;
    font-family: 'Lato', sans-serif;
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 0.5px;
    color: #ffffff;
  }
  .bc-dice-result a {
    color: var(--bc-gold);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
