---
import { withBase } from '../lib/url';

interface Props {
  active: 'home' | 'games' | 'reviews' | 'wall' | 'players' | 'wins' | 'rules';
}

const { active } = Astro.props;

const items = [
  { key: 'home', label: 'Home', href: withBase('/') },
  { key: 'players', label: 'Players', href: withBase('/players/') },
  { key: 'games', label: 'Games', href: withBase('/games/') },
  { key: 'reviews', label: 'Reviews', href: withBase('/reviews/') },
  { key: 'wins', label: 'Wins', href: withBase('/wins/') },
  { key: 'wall', label: 'Wall', href: withBase('/wall/') },
];

const resourceLinks = [
  { label: 'Rules', href: withBase('/rules/'), external: false },
  { label: 'The Scullery Kitchen Menu', href: 'https://www.knightwatchgames.com/the-scullery-kitchen', external: true },
];
---

<header class="bc-header">
  <div class="bc-header-inner">
    <a href={withBase('/')} class="bc-brand">
      <span class="bc-wordmark">BAILEYCON</span>
      <span class="bc-badge" title="Third Annual">
        <span class="bc-badge-bar"></span>
        <span class="bc-badge-bar"></span>
        <span class="bc-badge-bar"></span>
      </span>
    </a>

    <button
      type="button"
      class="bc-nav-toggle"
      id="bc-nav-toggle"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="bc-nav"
    >
      <span class="bc-nav-toggle-bar"></span>
      <span class="bc-nav-toggle-bar"></span>
      <span class="bc-nav-toggle-bar"></span>
    </button>

    <nav class="bc-nav" id="bc-nav">
      {items.map((it) => (
        <a href={it.href} class:list={['bc-nav-link', { 'is-active': it.key === active }]}>
          {it.label}
        </a>
      ))}

      <div class="bc-nav-dropdown">
        <button
          type="button"
          class:list={['bc-nav-link', 'bc-nav-dropdown-trigger', { 'is-active': active === 'rules' }]}
          id="bc-resources-toggle"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="bc-resources-menu"
        >
          Resources
          <span class="bc-nav-caret" aria-hidden="true">&#9662;</span>
        </button>
        <div class="bc-nav-dropdown-menu" id="bc-resources-menu">
          {resourceLinks.map((link) => (
            <a
              href={link.href}
              class="bc-nav-dropdown-link"
              {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </nav>
  </div>
</header>

<style>
  .bc-header {
    position: sticky;
    top: 0;
    z-index: 50;
    height: 52px;
    display: flex;
    align-items: center;
    background: var(--bc-chrome);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--bc-border-gold);
  }
  .bc-header-inner {
    width: 100%;
    max-width: var(--bc-max-width);
    margin: 0 auto;
    padding: 0 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }
  .bc-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  .bc-wordmark {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 26px;
    letter-spacing: 6px;
    background: linear-gradient(135deg, var(--bc-gold-light), var(--bc-gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .bc-badge {
    display: inline-flex;
    align-items: center;
    gap: 2.5px;
    background: var(--bc-blue);
    border-radius: 5px;
    padding: 5px 7px;
    box-shadow: 0 0 12px rgba(77, 163, 255, 0.45);
  }
  .bc-badge-bar {
    display: block;
    width: 2.5px;
    height: 11px;
    background: var(--bc-blue-deep);
    border-radius: 1px;
  }
  .bc-nav {
    display: flex;
    align-items: center;
    gap: 26px;
    flex-wrap: wrap;
  }
  .bc-nav-link {
    position: relative;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    font-weight: 700;
    color: rgba(255, 207, 92, 0.45);
    padding-bottom: 4px;
    border-bottom: 1px solid transparent;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.12s, border-color 0.12s;
  }
  .bc-nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 1px;
    background: var(--bc-gold);
    transform: scaleX(0) skewX(-8deg);
    transform-origin: left;
    transition: transform 0.18s ease;
  }
  .bc-nav-link:hover {
    color: var(--bc-gold);
  }
  .bc-nav-link:hover::after {
    transform: scaleX(1) skewX(-8deg);
  }
  .bc-nav-link.is-active {
    font-weight: 700;
    color: var(--bc-gold);
    border-bottom-color: rgba(255, 207, 92, 0.4);
  }

  .bc-nav-dropdown {
    position: relative;
  }
  .bc-nav-dropdown-trigger {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: none;
    border: none;
    border-bottom: 1px solid transparent;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    font-weight: 700;
    color: rgba(255, 207, 92, 0.45);
    cursor: pointer;
  }
  .bc-nav-dropdown-trigger:hover,
  .bc-nav-dropdown-trigger[aria-expanded='true'] {
    color: var(--bc-gold);
  }
  .bc-nav-caret {
    font-size: 9px;
    transition: transform 0.15s ease;
  }
  .bc-nav-dropdown-trigger[aria-expanded='true'] .bc-nav-caret {
    transform: rotate(180deg);
  }
  .bc-nav-dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + 14px);
    right: 0;
    min-width: 220px;
    background: #0d0a1c;
    border: 1px solid rgba(255, 207, 92, 0.2);
    border-radius: 9px;
    padding: 8px;
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.55);
    z-index: 60;
  }
  .bc-nav-dropdown-menu.is-open {
    display: block;
  }
  .bc-nav-dropdown-link {
    display: block;
    padding: 10px 12px;
    border-radius: 5px;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 12.5px;
    letter-spacing: 0.5px;
    text-transform: none;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.12s ease, color 0.12s ease;
  }
  .bc-nav-dropdown-link:hover {
    background: rgba(255, 207, 92, 0.1);
    color: var(--bc-gold);
  }

  .bc-nav-toggle {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 0;
    flex: none;
    border: 1px solid rgba(255, 207, 92, 0.4);
    border-radius: 6px;
    background: rgba(255, 207, 92, 0.08);
    cursor: pointer;
  }
  .bc-nav-toggle-bar {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--bc-gold);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .bc-nav-toggle[aria-expanded='true'] .bc-nav-toggle-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .bc-nav-toggle[aria-expanded='true'] .bc-nav-toggle-bar:nth-child(2) {
    opacity: 0;
  }
  .bc-nav-toggle[aria-expanded='true'] .bc-nav-toggle-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 760px) {
    .bc-header {
      height: auto;
    }
    .bc-header-inner {
      padding: 10px 18px;
      gap: 8px;
      position: relative;
    }
    .bc-wordmark {
      font-size: 22px;
      letter-spacing: 4px;
    }
    .bc-nav-toggle {
      display: flex;
    }
    .bc-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--bc-chrome);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--bc-border-gold);
      box-shadow: 0 14px 28px rgba(0, 0, 0, 0.45);
      padding: 4px 18px 10px;
    }
    .bc-nav.is-open {
      display: flex;
    }
    .bc-nav-link {
      padding: 13px 4px;
      text-align: center;
      border-bottom: 1px solid rgba(255, 207, 92, 0.12);
    }
    .bc-nav-link:last-child {
      border-bottom: none;
    }
    .bc-nav-dropdown {
      width: 100%;
    }
    .bc-nav-dropdown-trigger {
      width: 100%;
      justify-content: center;
    }
    .bc-nav > *:last-child .bc-nav-link,
    .bc-nav > *:last-child.bc-nav-link {
      border-bottom: none;
    }
    .bc-nav-dropdown-menu {
      position: static;
      min-width: 0;
      background: rgba(255, 207, 92, 0.05);
      border: none;
      border-radius: 0;
      box-shadow: none;
      backdrop-filter: none;
      padding: 4px 0;
    }
    .bc-nav-dropdown-link {
      text-align: center;
      padding: 12px 4px;
    }
  }
</style>

<script>
  const toggle = document.getElementById('bc-nav-toggle');
  const nav = document.getElementById('bc-nav');
  const resourcesToggle = document.getElementById('bc-resources-toggle');
  const resourcesMenu = document.getElementById('bc-resources-menu');

  function closeResourcesMenu() {
    resourcesMenu?.classList.remove('is-open');
    resourcesToggle?.setAttribute('aria-expanded', 'false');
  }

  function closeMenu() {
    nav?.classList.remove('is-open');
    toggle?.setAttribute('aria-expanded', 'false');
    closeResourcesMenu();
  }

  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });

  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('click', (e) => {
    if (!nav?.classList.contains('is-open')) return;
    const target = e.target as Node;
    if (nav.contains(target) || toggle?.contains(target)) return;
    closeMenu();
  });

  resourcesToggle?.addEventListener('click', () => {
    const isOpen = resourcesMenu?.classList.toggle('is-open');
    resourcesToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });

  document.addEventListener('click', (e) => {
    if (!resourcesMenu?.classList.contains('is-open')) return;
    const target = e.target as Node;
    if (resourcesMenu.contains(target) || resourcesToggle?.contains(target)) return;
    closeResourcesMenu();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
