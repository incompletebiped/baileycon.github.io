---
import Crest from './Crest.astro';
import { withBase } from '../lib/url';

interface Props {
  active: 'home' | 'games' | 'reviews' | 'wall' | 'guests';
}

const { active } = Astro.props;

const items = [
  { key: 'home', label: 'Home', href: withBase('/') },
  { key: 'games', label: 'Games', href: withBase('/games/') },
  { key: 'reviews', label: 'Reviews', href: withBase('/reviews/') },
  { key: 'wall', label: 'Wall', href: withBase('/wall/') },
  { key: 'guests', label: 'Guests', href: withBase('/guests/') },
];
---

<header class="bc-header">
  <div class="bc-header-inner">
    <a href={withBase('/')} class="bc-brand">
      <Crest size={40} />
      <span class="bc-wordmark">BaileyCon</span>
      <span class="bc-badge">III</span>
    </a>

    <button
      type="button"
      class="bc-nav-toggle"
      id="bc-nav-toggle"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="bc-nav"
    >
      <span class="bc-nav-toggle-bar"></span>
      <span class="bc-nav-toggle-bar"></span>
      <span class="bc-nav-toggle-bar"></span>
    </button>

    <nav class="bc-nav" id="bc-nav">
      {items.map((it) => (
        <a href={it.href} class:list={['bc-nav-link', { 'is-active': it.key === active }]}>
          {it.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .bc-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(14, 10, 48, 0.82);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 207, 92, 0.35);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
  }
  .bc-header-inner {
    max-width: var(--bc-max-width);
    margin: 0 auto;
    padding: 12px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }
  .bc-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }
  .bc-wordmark {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 27px;
    letter-spacing: 1.5px;
    background: linear-gradient(180deg, var(--bc-gold-lighter), var(--bc-gold) 60%, var(--bc-gold-deep));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .bc-badge {
    font-family: 'Cinzel', serif;
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 2px;
    color: #141048;
    background: #3f74f2;
    padding: 3px 7px;
    border-radius: 3px;
  }
  .bc-nav {
    display: flex;
    align-items: center;
    gap: 22px;
    flex-wrap: wrap;
  }
  .bc-nav-link {
    font-family: 'Cinzel', serif;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--bc-blue-muted);
    padding-bottom: 4px;
    border-bottom: 2px solid transparent;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.12s, border-color 0.12s;
  }
  .bc-nav-link:hover {
    color: var(--bc-gold-light);
  }
  .bc-nav-link.is-active {
    font-weight: 700;
    color: var(--bc-gold);
    border-bottom-color: var(--bc-gold);
  }

  .bc-nav-toggle {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 0;
    flex: none;
    border: 1px solid rgba(255, 207, 92, 0.5);
    border-radius: 6px;
    background: rgba(139, 107, 255, 0.12);
    cursor: pointer;
  }
  .bc-nav-toggle-bar {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--bc-gold);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .bc-nav-toggle[aria-expanded='true'] .bc-nav-toggle-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .bc-nav-toggle[aria-expanded='true'] .bc-nav-toggle-bar:nth-child(2) {
    opacity: 0;
  }
  .bc-nav-toggle[aria-expanded='true'] .bc-nav-toggle-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 640px) {
    .bc-header-inner {
      padding: 10px 18px;
      gap: 8px;
      position: relative;
    }
    .bc-wordmark {
      font-size: 23px;
    }
    .bc-nav-toggle {
      display: flex;
    }
    .bc-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: rgba(14, 10, 48, 0.97);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255, 207, 92, 0.35);
      box-shadow: 0 14px 28px rgba(0, 0, 0, 0.45);
      padding: 4px 18px 10px;
    }
    .bc-nav.is-open {
      display: flex;
    }
    .bc-nav-link {
      padding: 13px 4px;
      text-align: center;
      border-bottom: 1px solid rgba(139, 107, 255, 0.18);
    }
    .bc-nav-link:last-child {
      border-bottom: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById('bc-nav-toggle');
  const nav = document.getElementById('bc-nav');

  function closeMenu() {
    nav?.classList.remove('is-open');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });

  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('click', (e) => {
    if (!nav?.classList.contains('is-open')) return;
    const target = e.target as Node;
    if (nav.contains(target) || toggle?.contains(target)) return;
    closeMenu();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
