---
interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
}

const { eyebrow, title, subtitle } = Astro.props;
---

<section class="bc-banner">
  <span class="bc-corner bc-corner-tl"></span>
  <span class="bc-corner bc-corner-tr"></span>
  <span class="bc-corner bc-corner-bl"></span>
  <span class="bc-corner bc-corner-br"></span>
  <div class="bc-banner-content">
    <div class="bc-eyebrow">{eyebrow}</div>
    <h1 class="bc-title">{title}</h1>
    <p class="bc-subtitle">{subtitle}</p>
  </div>
</section>

<style>
  .bc-banner {
    position: relative;
    overflow: hidden;
    text-align: center;
    padding: 64px 28px 44px;
    background: var(--bc-hero-gradient);
    border-bottom: 1px solid rgba(255, 207, 92, 0.15);
  }
  .bc-banner-content {
    position: relative;
    z-index: 2;
    max-width: 720px;
    margin: 0 auto;
  }
  .bc-corner {
    position: absolute;
    width: 26px;
    height: 26px;
    z-index: 1;
  }
  .bc-corner::before,
  .bc-corner::after {
    content: '';
    position: absolute;
    background: var(--bc-gold);
  }
  .bc-corner::before {
    width: 100%;
    height: 1px;
  }
  .bc-corner::after {
    width: 1px;
    height: 100%;
  }
  .bc-corner-tl {
    top: 18px;
    left: 18px;
  }
  .bc-corner-tl::before,
  .bc-corner-tl::after {
    top: 0;
    left: 0;
  }
  .bc-corner-tr {
    top: 18px;
    right: 18px;
  }
  .bc-corner-tr::before {
    top: 0;
    right: 0;
  }
  .bc-corner-tr::after {
    top: 0;
    right: 0;
  }
  .bc-corner-bl {
    bottom: 18px;
    left: 18px;
  }
  .bc-corner-bl::before {
    bottom: 0;
    left: 0;
  }
  .bc-corner-bl::after {
    bottom: 0;
    left: 0;
  }
  .bc-corner-br {
    bottom: 18px;
    right: 18px;
  }
  .bc-corner-br::before {
    bottom: 0;
    right: 0;
  }
  .bc-corner-br::after {
    bottom: 0;
    right: 0;
  }
  .bc-eyebrow {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 5px;
    color: var(--bc-eyebrow);
    margin-bottom: 14px;
    text-transform: uppercase;
  }
  .bc-title {
    margin: 0;
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 52px;
    background: linear-gradient(135deg, var(--bc-gold-light), var(--bc-gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .bc-subtitle {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 700;
    font-size: 18px;
    color: var(--bc-muted);
    max-width: 620px;
    margin: 20px auto 0;
    line-height: 1.5;
  }

  @media (max-width: 480px) {
    .bc-banner {
      padding: 44px 18px 32px;
    }
    .bc-title {
      font-size: 30px;
    }
    .bc-subtitle {
      font-size: 16px;
    }
  }
</style>
