---
interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
}

const { eyebrow, title, subtitle } = Astro.props;
---

<section class="bc-banner">
  <div class="bc-banner-content">
    <div class="bc-fleuron">&#9670;</div>
    <div class="bc-eyebrow">{eyebrow}</div>
    <h1 class="bc-title">{title}</h1>
    <div class="bc-swash"></div>
    <p class="bc-subtitle">{subtitle}</p>
  </div>
</section>

<style>
  .bc-banner {
    position: relative;
    overflow: hidden;
    text-align: center;
    padding: 64px 28px 44px;
  }
  .bc-banner-content {
    position: relative;
    z-index: 2;
  }
  .bc-fleuron {
    color: var(--bc-blue-violet);
    font-size: 20px;
    margin-bottom: 6px;
  }
  .bc-eyebrow {
    font-family: 'Raleway', sans-serif;
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 6px;
    color: var(--bc-eyebrow);
    margin-bottom: 6px;
    text-transform: uppercase;
  }
  .bc-title {
    margin: 6px 0 0;
    font-family: 'Cinzel Decorative', serif;
    font-weight: 900;
    font-size: 64px;
    color: var(--bc-ink-strong);
    line-height: 1;
    text-transform: uppercase;
  }
  .bc-swash {
    width: 86px;
    height: 4px;
    background: var(--bc-gold);
    border-radius: 3px;
    margin: 20px auto 0;
  }
  .bc-subtitle {
    font-family: 'Lato', sans-serif;
    font-size: 19px;
    color: var(--bc-muted);
    max-width: 640px;
    margin: 22px auto 0;
    line-height: 1.5;
  }

  @media (max-width: 480px) {
    .bc-banner {
      padding: 44px 18px 32px;
    }
    .bc-title {
      font-size: 40px;
    }
    .bc-subtitle {
      font-size: 18px;
    }
  }
</style>
