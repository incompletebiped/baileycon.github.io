---
import { withBase } from '../lib/url';

const links = [
  { label: 'Home', href: withBase('/') },
  { label: 'Players', href: withBase('/players/') },
  { label: 'Games', href: withBase('/games/') },
  { label: 'Reviews', href: withBase('/reviews/') },
  { label: 'Wins', href: withBase('/wins/') },
  { label: 'Wall', href: withBase('/wall/') },
  { label: 'Rules', href: withBase('/rules/') },
];
---

<footer class="bc-footer">
  <div class="bc-footer-inner">
    <nav class="bc-footer-nav">
      {links.map((l) => (
        <a href={l.href}>{l.label}</a>
      ))}
    </nav>
    <div class="bc-footer-tagline">BaileyCon &middot; III &middot; MMXXV</div>
  </div>
</footer>

<style>
  .bc-footer {
    border-top: 1px solid var(--bc-border-gold);
    background: var(--bc-chrome);
    margin-top: 40px;
  }
  .bc-footer-inner {
    max-width: var(--bc-max-width);
    margin: 0 auto;
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    text-align: center;
  }
  .bc-footer-nav {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .bc-footer-nav a {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 2px;
    color: rgba(255, 207, 92, 0.5);
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.12s;
  }
  .bc-footer-nav a:hover {
    color: var(--bc-gold);
  }
  .bc-footer-tagline {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1px;
    color: rgba(255, 255, 255, 0.35);
  }

  @media (max-width: 480px) {
    .bc-footer-inner {
      padding: 30px 22px;
    }
  }
</style>
