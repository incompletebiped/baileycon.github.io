---
import { withBase } from '../lib/url';
import { rarityStyles, statusStyles, pips, type Guest } from '../data/guests';

interface Props {
  guest: Guest;
}

const { guest } = Astro.props;
const rs = rarityStyles[guest.rarity];
const [str, chs, blf, sta] = guest.stats;

const pStr = pips(str);
const pChs = pips(chs);
const pBlf = pips(blf);
const pSta = pips(sta);
---

<div
  class="mtg-card"
  id={guest.slug}
  data-name={guest.name}
  data-slug={guest.slug}
  data-str={str}
  data-chs={chs}
  data-blf={blf}
  data-sta={sta}
  data-rarity-color={rs.rarityColor}
  style={`--rc:${rs.rarityColor}; background:${rs.frameGrad};`}
>
  <div class="mtg-titlebar" style={`background:${rs.titleBg};`}>
    <span class="mtg-name" style={`color:${rs.titleColor};`}>{guest.name}</span>
    <span class="mtg-sta-pips" data-stat-pips="sta" style={`color:${rs.rarityColor};`}>{pSta.filled}</span>
  </div>

  <div class="mtg-art">
    <div class="mtg-art-placeholder">
      <span>Drop {guest.name}&rsquo;s photo</span>
    </div>
    <img
      src={withBase(`/images/guests/${guest.slug}.jpg`)}
      alt={guest.name}
      class="mtg-art-image"
      loading="lazy"
      onerror="this.style.display='none'"
    />
    {guest.status && (
      <div class="mtg-locked-scrim">
        <span class="mtg-status-banner" style={`background:${statusStyles[guest.status].bg};color:${statusStyles[guest.status].color};`}>
          {guest.status}
        </span>
      </div>
    )}
    <span class="mtg-score-pill" data-score-slot hidden></span>
    <span class="mtg-shine"></span>
  </div>

  <div class="mtg-typeline" style={`background:${rs.titleBg};`}>
    <span>Legendary &mdash; {guest.title}</span>
    <span class="mtg-rarity-symbol" style={`color:${rs.rarityColor};`}>{rs.raritySymbol}</span>
  </div>

  <div class="mtg-stats">
    <div class="mtg-stat-row">
      <span class="mtg-stat-label">Strategy</span>
      <span class="mtg-stat-pips" data-stat-pips="str" style={`color:${rs.titleBg};`}>{pStr.filled}<span class="mtg-pip-empty">{pStr.empty}</span></span>
    </div>
    <div class="mtg-stat-row">
      <span class="mtg-stat-label">Chaos</span>
      <span class="mtg-stat-pips" data-stat-pips="chs" style={`color:${rs.titleBg};`}>{pChs.filled}<span class="mtg-pip-empty">{pChs.empty}</span></span>
    </div>
    <div class="mtg-stat-row">
      <span class="mtg-stat-label">Bluff</span>
      <span class="mtg-stat-pips" data-stat-pips="blf" style={`color:${rs.titleBg};`}>{pBlf.filled}<span class="mtg-pip-empty">{pBlf.empty}</span></span>
    </div>
    <div class="mtg-stat-divider"></div>
    <p class="mtg-flavor">{guest.bio}</p>
  </div>

  <div class="mtg-footer" style={`background:${rs.titleBg};`}>
    <span class="mtg-footer-fact">{guest.main} &middot; {guest.align}</span>
    <span class="mtg-pt-pill" data-pt-pill style={`border-color:${rs.ptBorder};`}>{str}/{sta}</span>
  </div>
</div>

<style>
  .mtg-card {
    position: relative;
    border: 6px solid #0a0805;
    border-radius: 11px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    scroll-margin-top: 90px;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s;
  }
  .mtg-card:hover {
    transform: perspective(700px) rotateY(6deg) rotateX(-4deg) translateY(-10px);
    box-shadow: -8px 14px 40px rgba(0, 0, 0, 0.75), 0 0 28px var(--rc);
    z-index: 10;
  }
  .mtg-card:hover .mtg-shine {
    animation: mtg-shine 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .mtg-card.bc-highlight {
    animation: bc-guest-highlight-pulse 1.7s ease;
  }
  @keyframes bc-guest-highlight-pulse {
    0%,
    100% {
      box-shadow: none;
    }
    25% {
      box-shadow: 0 0 0 4px rgba(255, 207, 92, 0.85);
    }
  }
  .mtg-card.battle-sel {
    animation: battle-pulse 1.5s ease-in-out infinite;
  }
  @keyframes battle-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 3px #ffcf5c, 0 0 28px rgba(255, 207, 92, 0.4);
    }
    50% {
      box-shadow: 0 0 0 3px #ffcf5c, 0 0 48px rgba(255, 207, 92, 0.75);
    }
  }
  .mtg-titlebar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 6px;
    padding: 7px 10px;
  }
  .mtg-name {
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-size: 14px;
  }
  .mtg-sta-pips {
    font-size: 10px;
    filter: drop-shadow(0 0 4px currentColor);
  }
  .mtg-art {
    position: relative;
    height: 180px;
    background: #04020c;
    border-top: 2px solid #000;
    border-bottom: 2px solid #000;
    overflow: hidden;
  }
  .mtg-art-placeholder {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0 10px, rgba(255, 255, 255, 0.03) 10px 20px);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 16px;
  }
  .mtg-art-placeholder span {
    font-family: ui-monospace, Menlo, monospace;
    font-size: 10px;
    letter-spacing: 1px;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
  }
  .mtg-art-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .mtg-locked-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 45%, rgba(0, 0, 0, 0.75) 100%);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 10px;
  }
  .mtg-status-banner {
    transform: rotate(-5deg);
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 9.5px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 3px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
  }
  .mtg-score-pill {
    position: absolute;
    top: 8px;
    right: 8px;
    z-index: 3;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 9px;
    letter-spacing: 1px;
    color: var(--bc-gold);
    border: 1px solid var(--bc-gold);
    border-radius: 20px;
    padding: 2px 8px;
    text-transform: uppercase;
    background: rgba(6, 4, 15, 0.6);
    backdrop-filter: blur(2px);
  }
  .mtg-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(108deg, transparent 28%, rgba(255, 255, 255, 0.18) 50%, transparent 72%);
    transform: translateX(-120%) skewX(-18deg);
    pointer-events: none;
    z-index: 2;
  }
  @keyframes mtg-shine {
    from {
      transform: translateX(-120%) skewX(-18deg);
    }
    to {
      transform: translateX(280%) skewX(-18deg);
    }
  }
  .mtg-typeline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 4px 10px;
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 8px;
  }
  .mtg-typeline span:first-child {
    color: rgba(255, 255, 255, 0.75);
  }
  .mtg-rarity-symbol {
    filter: drop-shadow(0 0 4px currentColor);
  }
  .mtg-stats {
    flex: 1;
    background: linear-gradient(180deg, #f2e6c2 0%, #e8d8a8 100%);
    color: #2a1a06;
    font-family: Georgia, Times, serif;
    padding: 10px 12px 12px;
  }
  .mtg-stat-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 3px;
  }
  .mtg-stat-label {
    font-weight: 700;
    font-size: 7.5px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }
  .mtg-stat-pips {
    font-size: 11px;
    letter-spacing: 1.5px;
  }
  .mtg-pip-empty {
    color: rgba(42, 26, 6, 0.22);
  }
  .mtg-stat-divider {
    height: 1px;
    background: rgba(42, 26, 6, 0.22);
    margin: 6px 0 8px;
  }
  .mtg-flavor {
    font-style: italic;
    font-size: 9.5px;
    color: rgba(42, 26, 6, 0.7);
    margin: 0;
    line-height: 1.4;
  }
  .mtg-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 6px 10px;
  }
  .mtg-footer-fact {
    font-size: 7px;
    color: rgba(255, 255, 255, 0.7);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .mtg-pt-pill {
    flex: none;
    background: #e8d8a8;
    border: 1px solid;
    border-radius: 3px;
    padding: 1px 7px;
    font-family: Georgia, Times, serif;
    font-weight: 700;
    font-size: 12px;
    color: #1a0e02;
  }
</style>
