---
import { withBase } from '../lib/url';
import type { Game } from '../data/games';

interface DisplayGame extends Game {
  pips: string;
  weightLabel: string;
  hallColor: string;
  playersMin: number;
  playersMax: number;
  timeMin: number;
  timeMax: number;
  winPoints: number;
}

interface Props {
  game: DisplayGame;
  compact?: boolean;
  idx?: number;
}

const { game, compact = false, idx = 0 } = Astro.props;
---

{compact ? (
  <div class="bc-game-card--compact">
    <div class="bc-game-name">{game.name}</div>
    <p class="bc-game-tag">{game.tag}</p>
    <div class="bc-game-meta">
      <span>{game.players}</span><span>&middot;</span><span>{game.time}</span>
    </div>
  </div>
) : (
  <div class="bc-hero" data-hero data-idx={idx} data-slug={game.slug} hidden={idx !== 0}>
    <div class="bc-hero-info">
      <div class="bc-hero-badges">
        <span class="bc-room-badge" style={`background:${game.hallColor};`}>{game.hall}</span>
        {game.neverPlayed && <span class="bc-badge-outline">First Run</span>}
        <span class="bc-badge-played" data-played-badge hidden>&#10003; Played</span>
      </div>
      <h2 class="bc-hero-title">{game.name}</h2>
      <div class="bc-hero-diamonds" style={`color:${game.hallColor};`}>{game.pips}</div>
      <p class="bc-hero-desc">{game.tag}</p>
      <div class="bc-hero-meta">
        <div class="bc-hero-stat">
          <div class="bc-hero-stat-label">Players</div>
          <div class="bc-hero-stat-value">{game.players}</div>
        </div>
        <div class="bc-hero-stat">
          <div class="bc-hero-stat-label">Time</div>
          <div class="bc-hero-stat-value">{game.time}</div>
        </div>
        <div class="bc-hero-stat">
          <div class="bc-hero-stat-label">Win Value</div>
          <div class="bc-hero-stat-value" style={`color:${game.hallColor};`}>{game.winPoints} PTS</div>
        </div>
      </div>
      <div class="bc-hero-rating" data-rating-slot hidden></div>

      <div class="bc-hero-controls">
        <button type="button" class="bc-randomize-btn" data-randomize-btn>
          <span data-randomize-label>&#127922; Randomize</span>
        </button>
        <label class="bc-played-toggle" data-toggle-played>
          <span class="bc-played-box" data-played-box></span>
          <span class="bc-played-label" data-played-label>Already Played</span>
        </label>
      </div>
    </div>

    <div class="bc-hero-art">
      <div class="bc-art-placeholder">
        <span>box art &mdash; drop image</span>
      </div>
      <img
        src={withBase(`/images/games/${game.slug}.jpg`)}
        alt={game.name}
        class="bc-art-image"
        loading="lazy"
        onerror="this.style.display='none'"
      />
    </div>
  </div>
)}

<style>
  .bc-game-card--compact {
    border-radius: 10px 10px 0 0;
    padding: 20px 20px 22px;
    background: var(--bc-panel);
    border: 1px solid var(--bc-border-gold);
    border-top: none;
    height: 100%;
  }
  .bc-game-name {
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-size: 20px;
    color: #fff;
    line-height: 1.1;
  }
  .bc-game-tag {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.55);
    margin: 10px 0 0;
    line-height: 1.5;
  }
  .bc-game-meta {
    display: flex;
    gap: 10px;
    margin-top: 14px;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.4);
  }

  .bc-hero[hidden] {
    display: none;
  }
  .bc-hero {
    display: flex;
    gap: 40px;
    align-items: flex-start;
  }
  .bc-hero-info {
    flex: 1;
    min-width: 0;
  }
  .bc-hero-badges {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
  }
  .bc-room-badge {
    color: #06040f;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 8.5px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 3px;
  }
  .bc-badge-outline {
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.48);
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 8.5px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 3px;
  }
  .bc-badge-played {
    background: rgba(77, 163, 255, 0.2);
    border: 1px solid rgba(77, 163, 255, 0.55);
    color: var(--bc-blue);
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 8.5px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 3px;
  }
  .bc-hero-title {
    margin: 0 0 10px;
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: clamp(30px, 3.8vw, 58px);
    color: #fff;
    line-height: 1.05;
  }
  .bc-hero-diamonds {
    font-size: 18px;
    letter-spacing: 3px;
    margin-bottom: 16px;
  }
  .bc-hero-desc {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 17px;
    color: rgba(255, 255, 255, 0.7);
    max-width: 520px;
    margin: 0 0 22px;
    line-height: 1.55;
  }
  .bc-hero-meta {
    display: flex;
    gap: 34px;
    margin-bottom: 10px;
  }
  .bc-hero-stat-label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
  }
  .bc-hero-stat-value {
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 20px;
    color: #fff;
    margin-top: 4px;
  }
  .bc-hero-rating {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 13px;
    color: var(--bc-gold);
    margin-bottom: 6px;
  }
  .bc-hero-controls {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    margin-top: 18px;
  }
  .bc-randomize-btn {
    background: transparent;
    border: 1px solid rgba(255, 207, 92, 0.4);
    color: var(--bc-gold);
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1px;
    padding: 12px 20px;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .bc-randomize-btn:hover {
    background: rgba(255, 207, 92, 0.1);
  }
  .bc-played-toggle {
    display: flex;
    align-items: center;
    gap: 9px;
    cursor: pointer;
    user-select: none;
  }
  .bc-played-box {
    width: 22px;
    height: 22px;
    border-radius: 5px;
    border: 1.5px solid rgba(255, 255, 255, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    color: #06040f;
    flex: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .bc-played-label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.5);
    transition: color 0.15s;
  }

  .bc-hero-art {
    position: relative;
    flex: none;
    width: min(320px, 34vw);
    aspect-ratio: 3 / 4;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--bc-border-gold);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  }
  .bc-art-placeholder {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0 10px, rgba(255, 255, 255, 0.03) 10px 20px);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 20px;
  }
  .bc-art-placeholder span {
    font-family: ui-monospace, Menlo, monospace;
    font-size: 11px;
    letter-spacing: 1px;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
  }
  .bc-art-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 760px) {
    .bc-hero {
      flex-direction: column;
      gap: 24px;
    }
    .bc-hero-art {
      width: 100%;
      max-width: 320px;
      align-self: center;
    }
    .bc-hero-desc {
      max-width: none;
    }
  }
</style>
