---
import { withBase } from '../lib/url';

interface Game {
  slug: string;
  name: string;
  tag: string;
  players: string;
  time: string;
  weight?: string;
  pips?: string;
  hall?: string;
  hallColor?: string;
}

interface Props {
  game: Game;
  compact?: boolean;
}

const { game, compact = false } = Astro.props;
---

{compact ? (
  <div class="bc-game-card bc-game-card--compact">
    <div class="bc-game-name">{game.name}</div>
    <p class="bc-game-tag">{game.tag}</p>
    <div class="bc-game-meta">
      <span>{game.players}</span><span>&middot;</span><span>{game.time}</span>
    </div>
  </div>
) : (
  <div class="bc-game-card">
    <div class="bc-art-wrap">
      <div class="bc-art-placeholder">
        <span>box art &mdash; drop image</span>
      </div>
      <img
        src={withBase(`/images/games/${game.slug}.jpg`)}
        alt={game.name}
        class="bc-art-image"
        loading="lazy"
        onerror="this.style.display='none'"
      />
      <span class="bc-hall-pill" style={`color:${game.hallColor};border-color:${game.hallColor};`}>{game.hall}</span>
    </div>
    <div class="bc-game-body">
      <div class="bc-game-head">
        <div class="bc-game-name">{game.name}</div>
        <div class="bc-game-pips">{game.pips}</div>
      </div>
      <p class="bc-game-tag bc-game-tag--full">{game.tag}</p>
      <div class="bc-game-stats">
        <div class="bc-stat">
          <div class="bc-stat-label">PLAYERS</div>
          <div class="bc-stat-value">{game.players}</div>
        </div>
        <div class="bc-stat">
          <div class="bc-stat-label">TIME</div>
          <div class="bc-stat-value">{game.time}</div>
        </div>
        <div class="bc-stat bc-stat--last">
          <div class="bc-stat-label">WEIGHT</div>
          <div class="bc-stat-value">{game.weight}</div>
        </div>
      </div>
    </div>
  </div>
)}

<style>
  .bc-game-card {
    border: 1px solid rgba(139, 107, 255, 0.4);
    border-radius: 10px;
    background: var(--bc-card-gradient);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
    height: 100%;
  }
  .bc-game-card--compact {
    border-radius: 8px;
    padding: 20px 20px 22px;
  }
  .bc-art-wrap {
    position: relative;
    height: 120px;
    border-bottom: 1px solid rgba(139, 107, 255, 0.35);
    overflow: hidden;
  }
  .bc-art-placeholder {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(135deg, rgba(139, 107, 255, 0.18) 0 10px, rgba(139, 107, 255, 0.07) 10px 20px);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .bc-art-placeholder span {
    font-family: ui-monospace, Menlo, monospace;
    font-size: 11px;
    letter-spacing: 1px;
    color: rgba(230, 221, 255, 0.5);
    text-transform: uppercase;
  }
  .bc-art-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .bc-hall-pill {
    position: absolute;
    top: 10px;
    right: 10px;
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 1.5px;
    border: 1px solid;
    border-radius: 20px;
    padding: 3px 10px;
    text-transform: uppercase;
    background: rgba(14, 10, 48, 0.55);
    backdrop-filter: blur(2px);
  }
  .bc-game-body {
    padding: 20px 22px 22px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .bc-game-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
  }
  .bc-game-name {
    font-family: 'Cinzel Decorative', serif;
    font-weight: 700;
    font-size: 23px;
    color: var(--bc-gold);
    line-height: 1.05;
  }
  .bc-game-card--compact .bc-game-name {
    font-size: 20px;
  }
  .bc-game-pips {
    font-family: 'Cinzel', serif;
    font-size: 13px;
    letter-spacing: 1px;
    white-space: nowrap;
    color: var(--bc-gold);
  }
  .bc-game-tag {
    font-family: 'IM Fell English', serif;
    font-style: italic;
    font-size: 16px;
    color: var(--bc-text-muted);
    margin: 10px 0 16px;
    line-height: 1.45;
  }
  .bc-game-card--compact .bc-game-tag {
    font-size: 15px;
    margin-top: 8px;
    margin-bottom: 0;
  }
  .bc-game-tag--full {
    flex: 1;
  }
  .bc-game-meta {
    display: flex;
    gap: 14px;
    margin-top: 14px;
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--bc-text-faint);
  }
  .bc-game-stats {
    display: flex;
    gap: 0;
    border-top: 1px solid rgba(139, 107, 255, 0.3);
    padding-top: 14px;
  }
  .bc-stat {
    flex: 1;
    text-align: center;
    border-right: 1px solid rgba(139, 107, 255, 0.22);
  }
  .bc-stat--last {
    border-right: none;
  }
  .bc-stat-label {
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 1.5px;
    color: var(--bc-text-faint);
  }
  .bc-stat-value {
    font-family: 'Cinzel', serif;
    font-weight: 600;
    font-size: 15px;
    color: #e6f0ff;
    margin-top: 3px;
  }
</style>
