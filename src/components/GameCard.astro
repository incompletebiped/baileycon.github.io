---
import { withBase } from '../lib/url';

interface Game {
  slug: string;
  name: string;
  tag: string;
  players: string;
  time: string;
  weight?: string;
  pips?: string;
  hall?: string;
  hallColor?: string;
  playersMin?: number;
  playersMax?: number;
  timeMin?: number;
  neverPlayed?: boolean;
  winPoints?: number;
}

interface Props {
  game: Game;
  compact?: boolean;
}

const { game, compact = false } = Astro.props;
---

{compact ? (
  <div class="bc-game-card bc-game-card--compact">
    <div class="bc-game-name">{game.name}</div>
    <p class="bc-game-tag">{game.tag}</p>
    <div class="bc-game-meta">
      <span>{game.players}</span><span>&middot;</span><span>{game.time}</span>
    </div>
  </div>
) : (
  <div
    class="bc-game-card"
    id={game.slug}
    data-name={game.name}
    data-players-min={game.playersMin ?? 0}
    data-players-max={game.playersMax ?? 99}
    data-time-min={game.timeMin ?? 0}
    data-weight={game.weight ?? 1}
  >
    <div
      class="bc-art-wrap"
      data-lightbox-trigger
      data-lightbox-img={withBase(`/images/games/${game.slug}.jpg`)}
      data-lightbox-name={game.name}
      role="button"
      tabindex="0"
      aria-label={`View full box art for ${game.name}`}
    >
      <div class="bc-art-placeholder">
        <span>box art &mdash; drop image</span>
      </div>
      <img
        src={withBase(`/images/games/${game.slug}.jpg`)}
        alt={game.name}
        class="bc-art-image"
        loading="lazy"
        onerror="this.style.display='none'"
      />
      <span class="bc-art-zoom-hint" aria-hidden="true">&#10021;</span>
      {game.neverPlayed && <span class="bc-never-played-pill">Never Played</span>}
      <span class="bc-hall-pill" style={`color:${game.hallColor};border-color:${game.hallColor};`}>{game.hall}</span>
    </div>
    <div class="bc-game-body">
      <div class="bc-game-head">
        <div class="bc-game-name">{game.name}</div>
        <div class="bc-game-pips">{game.pips}</div>
      </div>
      <div class="bc-game-rating" data-rating-slot hidden></div>
      <p class="bc-game-tag bc-game-tag--full">{game.tag}</p>
      <div class="bc-game-stats">
        <div class="bc-stat">
          <div class="bc-stat-label">PLAYERS</div>
          <div class="bc-stat-value">{game.players}</div>
        </div>
        <div class="bc-stat">
          <div class="bc-stat-label">TIME</div>
          <div class="bc-stat-value">{game.time}</div>
        </div>
        <div class="bc-stat bc-stat--last">
          <div class="bc-stat-label">WIN VALUE</div>
          <div class="bc-stat-value">{game.winPoints ?? game.weight} PTS</div>
        </div>
      </div>
    </div>
  </div>
)}

<style>
  .bc-game-card {
    border: 1px solid rgba(139, 107, 255, 0.4);
    border-radius: 10px;
    background: var(--bc-card-gradient);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
    height: 100%;
    scroll-margin-top: 90px;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }
  .bc-game-card:hover {
    transform: scale(1.035);
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.45);
  }
  .bc-game-card.bc-highlight {
    animation: bc-highlight-pulse 1.7s ease;
  }
  @keyframes bc-highlight-pulse {
    0%,
    100% {
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
    }
    25% {
      box-shadow: 0 0 0 4px rgba(255, 207, 92, 0.85), 0 8px 24px rgba(0, 0, 0, 0.35);
    }
  }
  .bc-game-card--compact {
    border-radius: 8px;
    padding: 20px 20px 22px;
  }
  .bc-art-wrap {
    position: relative;
    height: 120px;
    border-bottom: 1px solid rgba(139, 107, 255, 0.35);
    overflow: hidden;
    cursor: pointer;
  }
  .bc-art-wrap:focus-visible {
    outline: 2px solid var(--bc-gold);
    outline-offset: -2px;
  }
  .bc-art-zoom-hint {
    position: absolute;
    bottom: 8px;
    right: 8px;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: rgba(14, 10, 48, 0.7);
    border: 1px solid var(--bc-gold);
    color: var(--bc-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    opacity: 0;
    transition: opacity 0.18s ease;
    pointer-events: none;
    z-index: 1;
  }
  .bc-art-wrap:hover .bc-art-zoom-hint,
  .bc-art-wrap:focus-visible .bc-art-zoom-hint {
    opacity: 1;
  }
  .bc-art-placeholder {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(135deg, rgba(139, 107, 255, 0.18) 0 10px, rgba(139, 107, 255, 0.07) 10px 20px);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .bc-art-placeholder span {
    font-family: ui-monospace, Menlo, monospace;
    font-size: 11px;
    letter-spacing: 1px;
    color: rgba(230, 221, 255, 0.5);
    text-transform: uppercase;
  }
  .bc-art-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .bc-hall-pill {
    position: absolute;
    top: 10px;
    right: 10px;
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 1.5px;
    border: 1px solid;
    border-radius: 20px;
    padding: 3px 10px;
    text-transform: uppercase;
    background: rgba(14, 10, 48, 0.55);
    backdrop-filter: blur(2px);
  }
  .bc-never-played-pill {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 1;
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 1.5px;
    color: var(--bc-gold);
    border: 1px solid var(--bc-gold);
    border-radius: 20px;
    padding: 3px 10px;
    text-transform: uppercase;
    background: rgba(14, 10, 48, 0.55);
    backdrop-filter: blur(2px);
  }
  .bc-game-body {
    padding: 20px 22px 22px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .bc-game-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
  }
  .bc-game-name {
    font-family: 'Cinzel Decorative', serif;
    font-weight: 700;
    font-size: 23px;
    color: var(--bc-gold);
    line-height: 1.05;
  }
  .bc-game-card--compact .bc-game-name {
    font-size: 20px;
  }
  .bc-game-pips {
    font-family: 'Cinzel', serif;
    font-size: 13px;
    letter-spacing: 1px;
    white-space: nowrap;
    color: var(--bc-gold);
  }
  .bc-game-rating {
    font-family: 'Cinzel', serif;
    font-size: 12px;
    letter-spacing: 0.5px;
    color: var(--bc-gold);
    margin-top: 6px;
  }
  .bc-game-tag {
    font-family: 'Lato', sans-serif;
    font-size: 16px;
    color: var(--bc-text-bright);
    margin: 10px 0 16px;
    line-height: 1.5;
  }
  .bc-game-card--compact .bc-game-tag {
    font-size: 15px;
    margin-top: 8px;
    margin-bottom: 0;
  }
  .bc-game-tag--full {
    flex: 1;
  }
  .bc-game-meta {
    display: flex;
    gap: 14px;
    margin-top: 14px;
    font-family: 'Cinzel', serif;
    font-size: 12px;
    letter-spacing: 1px;
    color: var(--bc-text-faint-bright);
  }
  .bc-game-stats {
    display: flex;
    gap: 0;
    border-top: 1px solid rgba(139, 107, 255, 0.3);
    padding-top: 14px;
  }
  .bc-stat {
    flex: 1;
    text-align: center;
    border-right: 1px solid rgba(139, 107, 255, 0.22);
  }
  .bc-stat--last {
    border-right: none;
  }
  .bc-stat-label {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 1.5px;
    color: var(--bc-text-faint-bright);
  }
  .bc-stat-value {
    font-family: 'Cinzel', serif;
    font-weight: 600;
    font-size: 16px;
    color: #e6f0ff;
    margin-top: 4px;
  }
</style>

<style is:global>
  .bc-lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 60px 40px;
    background: rgba(8, 6, 26, 0.88);
    backdrop-filter: blur(3px);
  }
  .bc-lightbox.is-open {
    display: flex;
  }
  .bc-lightbox-img {
    max-width: 90vw;
    max-height: 80vh;
    border: 2px solid var(--bc-gold);
    border-radius: 8px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
    object-fit: contain;
  }
  .bc-lightbox-caption {
    position: absolute;
    bottom: 26px;
    left: 0;
    right: 0;
    text-align: center;
    font-family: 'Cinzel', serif;
    letter-spacing: 1px;
    font-size: 15px;
    color: var(--bc-gold);
  }
  .bc-lightbox-close {
    position: absolute;
    top: 22px;
    right: 30px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(14, 10, 48, 0.7);
    border: 1px solid var(--bc-gold);
    color: var(--bc-gold);
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
  }
  body.bc-lightbox-lock {
    overflow: hidden;
  }
</style>

<script>
  function ensureLightbox(): HTMLElement {
    let modal = document.getElementById('bc-lightbox') as HTMLElement | null;
    if (modal) return modal;

    modal = document.createElement('div');
    modal.id = 'bc-lightbox';
    modal.className = 'bc-lightbox';
    modal.innerHTML = `
      <button type="button" class="bc-lightbox-close" aria-label="Close">&times;</button>
      <img class="bc-lightbox-img" alt="" />
      <div class="bc-lightbox-caption"></div>
    `;
    document.body.appendChild(modal);

    const close = () => {
      modal!.classList.remove('is-open');
      document.body.classList.remove('bc-lightbox-lock');
    };

    modal.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target === modal || target.closest('.bc-lightbox-close')) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });

    return modal;
  }

  function openLightbox(src: string, name: string) {
    const modal = ensureLightbox();
    const img = modal.querySelector('.bc-lightbox-img') as HTMLImageElement;
    const caption = modal.querySelector('.bc-lightbox-caption') as HTMLElement;
    img.src = src;
    img.alt = name;
    caption.textContent = name;
    modal.classList.add('is-open');
    document.body.classList.add('bc-lightbox-lock');
  }

  function triggerFrom(target: EventTarget | null): HTMLElement | null {
    return target instanceof HTMLElement ? target.closest('[data-lightbox-trigger]') : null;
  }

  document.addEventListener('click', (e) => {
    const trigger = triggerFrom(e.target);
    if (!trigger) return;
    const src = trigger.getAttribute('data-lightbox-img');
    const name = trigger.getAttribute('data-lightbox-name') || '';
    if (src) openLightbox(src, name);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter' && e.key !== ' ') return;
    const trigger = triggerFrom(e.target);
    if (!trigger) return;
    e.preventDefault();
    const src = trigger.getAttribute('data-lightbox-img');
    const name = trigger.getAttribute('data-lightbox-name') || '';
    if (src) openLightbox(src, name);
  });
</script>
