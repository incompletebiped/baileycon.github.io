---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../lib/url';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  active: 'home' | 'games' | 'reviews' | 'wall' | 'players' | 'wins' | 'rules';
}

const { title, description = 'BaileyCon — Third Annual, a private board-game convention at Knight Watch Games, San Antonio TX.', active } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Bangers&family=Cinzel:wght@400;600;700&family=Cinzel+Decorative:wght@700;900&family=Lato:wght@400;700;900&family=Raleway:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <Header active={active} />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
